---
import '../styles/global.css';
// Dashboard pelamar Mahardhika: Life at PIH dengan sinkronisasi data detail
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard Pelamar | Life at PIH</title>
    <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Funnel Display', sans-serif; }
        .glass-card { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
        
        #celebration-modal {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: rgba(15, 40, 84, 0.6);
            backdrop-filter: blur(10px);
        }
        #celebration-modal.active { display: flex; animation: fadeIn 0.5s ease forwards; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        
        .modal-box {
            transform: translateY(20px);
            opacity: 0;
            transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        #celebration-modal.active .modal-box { transform: translateY(0); opacity: 1; }
        .progress-dot { transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
    </style>
</head>
<body class="bg-slate-50 min-h-screen pb-20">

    <!-- MODAL NOTIFIKASI PERSISTEN -->
    <div id="celebration-modal">
        <div class="modal-box bg-white max-w-sm w-full p-10 rounded-[3rem] text-center shadow-2xl relative overflow-hidden border border-slate-100">
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-400/10 rounded-full blur-3xl"></div>
            <div id="modal-bg-deco" class="absolute -bottom-10 -left-10 w-32 h-32 bg-yellow-400/10 rounded-full blur-3xl"></div>
            
            <div id="modal-icon" class="text-6xl mb-6 scale-110">🎉</div>
            <h2 id="modal-title" class="text-2xl font-black text-slate-900 uppercase italic mb-3 leading-tight tracking-tighter">Selamat!</h2>
            <p id="modal-message" class="text-slate-500 text-sm leading-relaxed mb-8">Pesan status Anda akan muncul di sini.</p>
            
            <button id="close-modal-btn" class="w-full bg-[#1b509b] text-white py-4 rounded-2xl font-black uppercase tracking-widest text-[10px] shadow-lg shadow-blue-900/30 hover:scale-[1.03] active:scale-95 transition-all">
                Lanjutkan ke Dashboard
            </button>
        </div>
    </div>

    <nav class="bg-[#0f2854] text-white p-4 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto flex justify-between items-center text-sm font-bold">
            <div class="flex items-center gap-2">
                <div class="w-6 h-6 bg-white rounded flex items-center justify-center text-[#0f2854]">M</div>
                <span class="tracking-tighter uppercase">Mahardhika Dashboard</span>
            </div>
            <button id="logout-btn" class="text-red-400 text-[10px] uppercase tracking-widest hover:text-red-300 transition-colors">Logout</button>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto py-12 px-6">
        <div id="loading-state" class="text-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-blue-900 mx-auto"></div>
            <p class="mt-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Sinkronisasi Data Mahardhika...</p>
        </div>

        <div id="dashboard-content" class="hidden">
            <div id="active-banner" class="hidden mb-8 bg-blue-50 border border-blue-100 p-6 rounded-[2rem] flex items-center gap-4">
                <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center text-lg shadow-md">✓</div>
                <div>
                    <p class="text-xs font-black text-blue-900 uppercase tracking-widest">Aplikasi Terkirim</p>
                    <p class="text-sm text-blue-700/80 font-medium">Data Anda sedang dalam proses tinjauan administratif oleh tim PIH UIN Jakarta.</p>
                </div>
            </div>

            <h1 class="text-4xl font-extrabold text-slate-900 mb-8 italic uppercase tracking-tighter">Halo, <span id="user-name" class="text-[#1b509b]">-</span>!</h1>

            <!-- PROGRESS CARD -->
            <div class="glass-card p-10 rounded-[3rem] shadow-2xl shadow-blue-900/5 mb-10 overflow-hidden relative border-t-8 border-t-[#1b509b]">
                <div class="flex justify-between items-center mb-12 font-bold">
                    <span class="text-slate-500 uppercase text-[10px] tracking-[0.2em]">Tahapan Rekrutmen</span>
                    <span id="badge-status" class="px-4 py-1.5 rounded-full text-[9px] bg-slate-100 uppercase border border-slate-200 font-black tracking-widest">-</span>
                </div>
                
                <div class="relative px-6 pb-6">
                    <div class="absolute top-5 left-10 right-10 h-1.5 bg-slate-200/50 rounded-full"></div>
                    <div id="progress-bar" class="absolute top-5 left-10 h-1.5 bg-[#1b509b] transition-all duration-1000 ease-in-out rounded-full" style="width: 0%"></div>

                    <div class="flex justify-between relative">
                        {['administrasi', 'interview', 'final'].map((step, i) => (
                            <div class="step-item flex flex-col items-center w-24 group" data-step={step}>
                                <div class="circle progress-dot w-12 h-12 rounded-2xl bg-white border-4 border-slate-100 flex items-center justify-center font-black text-slate-300 z-10 shadow-sm transition-all duration-500">
                                    {i + 1}
                                </div>
                                <span class="mt-4 text-[9px] uppercase font-black text-center leading-tight tracking-widest text-slate-400">{step}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- DATA DETAIL LAMARAN -->
                <div class="lg:col-span-2 space-y-6">
                    <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm">
                        <h3 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-6 flex items-center gap-2">
                            <span class="w-8 h-px bg-slate-200"></span> Detail Aplikasi
                        </h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div>
                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-1">Posisi Pilihan 1 (Utama)</p>
                                <p id="role-1-val" class="text-lg font-black text-slate-800 italic leading-tight">-</p>
                            </div>
                            <div>
                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-1">Posisi Pilihan 2 (Cadangan)</p>
                                <p id="role-2-val" class="text-lg font-black text-blue-600 italic leading-tight">-</p>
                            </div>
                            <div>
                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-1">Fakultas / Program Studi</p>
                                <p id="academic-val" class="text-sm font-bold text-slate-700 leading-tight">-</p>
                            </div>
                            <div>
                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-1">NIM / Semester</p>
                                <p id="nim-val" class="text-sm font-bold text-slate-700 leading-tight">-</p>
                            </div>
                        </div>
                        
                        <div class="mt-8 pt-8 border-t border-slate-50">
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-2">Tautan Portofolio</p>
                            <a id="portfolio-link" href="#" target="_blank" class="text-xs font-black text-[#1b509b] underline truncate block">Belum ada link</a>
                        </div>
                    </div>

                    <div class="bg-slate-900 p-8 rounded-[3rem] text-white shadow-xl">
                        <h3 class="text-[10px] font-black uppercase tracking-widest text-blue-300 mb-4">Informasi Batch</h3>
                        <div class="flex items-center gap-4">
                            <div class="text-4xl">🏛️</div>
                            <div>
                                <p id="batch-name-val" class="text-xl font-black italic">Mahardhika Internship</p>
                                <p id="batch-id-val" class="text-[10px] opacity-50 font-bold uppercase tracking-widest">-</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SIDEBAR / TIMELINE -->
                <div class="space-y-6">
                    <div class="bg-[#1b509b] p-8 rounded-[3rem] text-white shadow-lg relative overflow-hidden">
                        <div class="absolute top-0 right-0 p-4 opacity-10 text-6xl">🗓️</div>
                        <h3 class="text-[10px] font-black uppercase tracking-widest mb-6 border-b border-white/10 pb-4">Timeline Seleksi</h3>
                        <ul class="space-y-4 text-[11px]">
                            <li class="flex justify-between opacity-50"><span>Pendaftaran</span> <span>11-25 Mar</span></li>
                            <li class="flex justify-between opacity-50"><span>Seleksi Berkas</span> <span>25-30 Mar</span></li>
                            <li class="flex justify-between font-bold text-yellow-400"><span>Wawancara</span> <span>1-2 Apr</span></li>
                            <li class="flex justify-between opacity-50"><span>Onboarding</span> <span>10 Apr</span></li>
                        </ul>
                    </div>
                    
                    <div class="p-8 border-2 border-dashed border-slate-200 rounded-[3rem] text-center">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Butuh Bantuan?</p>
                        <a href="https://wa.me/xxx" class="text-xs font-black text-[#1b509b] hover:underline">Hubungi Admin PIH</a>
                    </div>
                </div>
            </div>

            <div id="no-application" class="hidden text-center py-24 bg-white rounded-[3rem] border-2 border-dashed border-slate-200 shadow-inner">
                <div class="text-6xl mb-6">🚀</div>
                <h2 class="text-2xl font-black text-slate-800 uppercase italic mb-2">Mulai Langkahmu!</h2>
                <p class="mb-10 font-medium text-slate-400 text-sm max-w-xs mx-auto">Kamu belum mengirimkan lamaran untuk program Mahardhika Batch 9.</p>
                <a href="/join" class="bg-[#1b509b] text-white px-12 py-5 rounded-2xl font-black text-xs uppercase tracking-widest shadow-xl shadow-blue-900/20 hover:scale-105 transition-transform inline-block">Daftar Sekarang</a>
            </div>
        </div>
    </main>

    <script>
        import { supabase } from '../lib/supabase';

        const loadingState = document.getElementById('loading-state') as HTMLElement;
        const dashboardContent = document.getElementById('dashboard-content') as HTMLElement;
        const userName = document.getElementById('user-name') as HTMLElement;
        const badgeStatus = document.getElementById('badge-status') as HTMLElement;
        const progressBar = document.getElementById('progress-bar') as HTMLElement;
        
        // Value Fields
        const role1Val = document.getElementById('role-1-val') as HTMLElement;
        const role2Val = document.getElementById('role-2-val') as HTMLElement;
        const academicVal = document.getElementById('academic-val') as HTMLElement;
        const nimVal = document.getElementById('nim-val') as HTMLElement;
        const portfolioLink = document.getElementById('portfolio-link') as HTMLAnchorElement;
        const batchNameVal = document.getElementById('batch-name-val') as HTMLElement;
        const batchIdVal = document.getElementById('batch-id-val') as HTMLElement;

        const noApp = document.getElementById('no-application') as HTMLElement;
        const appliedBanner = document.getElementById('active-banner') as HTMLElement;

        // Modal
        const modal = document.getElementById('celebration-modal');
        const modalTitle = document.getElementById('modal-title');
        const modalMsg = document.getElementById('modal-message');
        const modalIcon = document.getElementById('modal-icon');
        const modalClose = document.getElementById('close-modal-btn');
        const modalDeco = document.getElementById('modal-bg-deco');

        let currentAppId = "";
        let lastStatus = "";

        async function init() {
            const { data: { user } } = await supabase.auth.getUser();
            if (!user) { window.location.href = '/'; return; }

            userName.innerText = user.user_metadata.full_name || "User";

            const { data: application, error } = await supabase
                .from('applications')
                .select('*')
                .eq('user_id', user.id)
                .order('created_at', { ascending: false })
                .maybeSingle();

            loadingState.classList.add('hidden');
            dashboardContent.classList.remove('hidden');

            if (!application) {
                noApp.classList.remove('hidden');
                document.querySelector('.grid')?.classList.add('hidden');
                document.querySelector('.glass-card')?.classList.add('hidden');
                return;
            }

            // Fill Data
            currentAppId = application.id;
            lastStatus = application.status;
            
            role1Val.innerText = application.role_applied;
            role2Val.innerText = application.role_2 || "Tidak ada pilihan ke-2";
            academicVal.innerText = `${application.faculty} / ${application.study_program}`;
            nimVal.innerText = `${application.nim} (Semester ${application.semester})`;
            portfolioLink.href = application.portfolio_url;
            portfolioLink.innerText = application.portfolio_url;
            batchIdVal.innerText = `ID: ${application.batch_id}`;

            appliedBanner.classList.remove('hidden');
            updateUI(application.status);

            if (application.status !== 'administrasi' && !application.acknowledged) {
                showNotification(application.status);
            }

            // Realtime Update
            supabase
                .channel('applicant-status')
                .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'applications', filter: `id=eq.${application.id}` },
                    async (payload) => {
                        const newStatus = payload.new.status;
                        if (newStatus !== lastStatus) {
                            await supabase.from('applications').update({ acknowledged: false }).eq('id', application.id);
                            showNotification(newStatus);
                            lastStatus = newStatus;
                            updateUI(newStatus);
                        }
                    }
                ).subscribe();
        }

        function showNotification(status: string) {
            if (!modal || !modalTitle || !modalMsg || !modalIcon) return;

            modalIcon.innerText = "🎉";
            modalTitle.innerText = "Selamat!";
            modalTitle.className = "text-2xl font-black text-slate-900 uppercase italic mb-3 tracking-tighter";
            modalClose!.className = "w-full bg-[#1b509b] text-white py-4 rounded-2xl font-black uppercase tracking-widest text-[10px] shadow-lg shadow-blue-900/30 hover:scale-[1.03] active:scale-95 transition-all";
            if (modalDeco) modalDeco.className = "absolute -bottom-10 -left-10 w-32 h-32 bg-yellow-400/10 rounded-full blur-3xl";

            if (status === 'interview') {
                modalIcon.innerText = "📩";
                modalTitle.innerText = "Lolos Berkas!";
                modalMsg.innerText = "Selamat! Kamu diundang untuk tahap wawancara Mahardhika Batch 9. Mohon tunggu informasi jadwal selanjutnya.";
            } else if (status === 'accepted') {
                modalIcon.innerText = "🎉";
                modalTitle.innerText = "Diterima Magang!";
                modalMsg.innerText = "Selamat bergabung dengan Squad PIH UIN Jakarta! Cek email kamu untuk surat pengantar dan jadwal Onboarding.";
            } else if (status === 'rejected') {
                modalIcon.innerText = "🤝"; 
                modalTitle.innerText = "Belum Berhasil";
                modalTitle.classList.replace('text-slate-900', 'text-rose-600');
                modalMsg.innerText = "Terima kasih atas minatmu di Mahardhika PIH. Tetap semangat dan jangan berhenti berkarya di lain kesempatan!";
                modalClose!.className = "w-full bg-slate-800 text-white py-4 rounded-2xl font-black uppercase tracking-widest text-[10px]";
                if (modalDeco) modalDeco.className = "absolute -bottom-10 -left-10 w-32 h-32 bg-rose-400/10 rounded-full blur-3xl";
            }
            
            modal.classList.add('active');
        }

        async function handleCloseModal() {
            if (!currentAppId) return;
            await supabase.from('applications').update({ acknowledged: true }).eq('id', currentAppId);
            modal?.classList.remove('active');
        }

        function updateUI(status: string) {
            badgeStatus.innerText = status;
            const steps = document.querySelectorAll('.step-item');
            let p = 0;
            if (status === 'interview') p = 50;
            if (status === 'accepted' || status === 'rejected') p = 100;
            progressBar.style.width = `${p}%`;

            steps.forEach((item) => {
                const s = (item as HTMLElement).dataset.step;
                const circle = item.querySelector('.circle') as HTMLElement;
                circle.classList.remove('border-[#1b509b]', 'bg-[#1b509b]', 'text-white', 'border-emerald-500', 'bg-emerald-500', 'border-rose-500', 'text-rose-500');

                if (status === 'administrasi' && s === 'administrasi') {
                    circle.classList.add('border-[#1b509b]', 'bg-[#1b509b]', 'text-white');
                } else if (status === 'interview' && (s === 'administrasi' || s === 'interview')) {
                    circle.classList.add('border-[#1b509b]', 'bg-[#1b509b]', 'text-white');
                } else if (status === 'accepted') {
                    circle.classList.add('border-emerald-500', 'bg-emerald-500', 'text-white');
                    badgeStatus.className = "px-4 py-1.5 rounded-full text-[9px] bg-emerald-50 text-emerald-600 border border-emerald-100 font-black uppercase tracking-widest";
                } else if (status === 'rejected') {
                    circle.classList.add('border-rose-500', 'text-rose-500');
                    badgeStatus.className = "px-4 py-1.5 rounded-full text-[9px] bg-rose-50 text-rose-600 border border-rose-100 font-black uppercase tracking-widest";
                }
            });
        }

        modalClose?.addEventListener('click', handleCloseModal);
        document.getElementById('logout-btn')?.addEventListener('click', async () => { await supabase.auth.signOut(); window.location.href = '/'; });

        init();
    </script>
</body>
</html>