---
import '../styles/global.css';
---

<html lang="id">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Life at PIH | Portofolio Interaktif</title>
        <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Playfair+Display:ital,wght@0,900;1,900&family=Bebas+Neue&family=Satisfy&display=swap" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:ital,wght@0,300;0,800;1,300&family=Inter:ital,wght@0,400;0,800;1,300&display=swap" rel="stylesheet">
        
        <style is:global>
            :root {
                --bg-color: #1b509b;
                --text-color: #ffffff;
                --border-white: rgba(255, 255, 255, 0.2);
                --pih-blue: #1b509b;
                --pih-dark: #0f2854;
            }

            body {
                font-family: 'Funnel Display', sans-serif;
                background-color: var(--bg-color) !important;
                color: var(--text-color) !important;
                overflow-x: hidden;
                margin: 0;
            }

            /* --- 1. HERO --- */
            .trail-dot { pointer-events: none; position: absolute; opacity: 0; z-index: 5; }
            .italic-text { font-style: italic; font-weight: 300; text-transform: lowercase; color: #ffffff; }

            /* --- 2. ROLES --- */
            .role-list-item { border-bottom: 1px solid var(--border-white) !important; cursor: none; transition: background-color 0.3s ease; }
            .swipe-image {
                position: fixed; top: 0; left: 0; width: 150px; height: 150px;
                z-index: 50; pointer-events: none; opacity: 0; visibility: hidden;
                border-radius: 50%; display: flex; align-items: center; justify-content: center;
                background: #0f2854; box-shadow: 0 10px 30px rgba(0,0,0,0.2); font-size: 4rem;
            }
            .role-title { transition: color 0.3s ease; color: #ffffff; }

            /* FLOATING DOCK STYLES */
            .dock-wrapper { position: fixed; bottom: 25px; left: 50%; transform: translateX(-50%); display: flex; justify-content: center; z-index: 1000; }
            .toolbar { display: inline-flex; justify-content: center; align-items: center; height: 65px; border-radius: 22px; padding: 0 15px; background-color: rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); list-style: none; border: 1px solid rgba(255, 255, 255, 0.2); box-shadow: 0 20px 40px rgba(0,0,0,0.3); margin: 0; }
            .toolbarItem { width: 45px; height: 45px; margin: 0 6px; position: relative; display: flex; align-items: center; justify-content: center; }
            .toolbarLink { display: flex; height: 100%; width: 100%; text-decoration: none; align-items: center; justify-content: center; background: white; border-radius: 12px; color: var(--pih-dark); transition: transform 0.3s ease, background 0.3s ease; }
            .toolbarLink:hover { transform: translateY(-5px); background: #f0f0f0; }
            .tooltip { position: absolute; top: -45px; left: 50%; transform: translateX(-50%); background: white; color: black; padding: 5px 12px; border-radius: 8px; font-size: 11px; font-weight: bold; opacity: 0; transition: opacity 0.2s; white-space: nowrap; pointer-events: none; box-shadow: 0 5px 15px rgba(0,0,0,0.2); }
            .toolbarItem:hover .tooltip { opacity: 1; }

            .shape-overlays { width: 100vw; height: 100vh; position: fixed; top: 0; left: 0; z-index: 50; pointer-events: none; }
            .shape-overlays.is-active { pointer-events: auto; }
            
            #footer { position: relative; z-index: 100; background-color: #000; }
            
            .auth-btn { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; }
            .auth-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
        </style>
    </head>
    <body class="antialiased">

        <div id="loader" class="fixed inset-0 z-[9999] flex items-center justify-center bg-[#1b509b]">
            <svg id="svg-loader" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 248 248" class="w-48 h-48 opacity-0">
                <g class="loader-g1">
                    <image href="https://assets.codepen.io/16327/flair-2.png" />
                    <image href="https://assets.codepen.io/16327/flair-2.png" />
                    <image href="https://assets.codepen.io/16327/flair-2.png" />
                </g>
                <g class="loader-g2">
                    <image href="https://assets.codepen.io/16327/flair-3.png" mask="url(#m2)"/>
                </g>
                <mask id="m2" fill="#fff"><circle cx="124" cy="0" r="0"/><circle cx="124" cy="248" r="0"/></mask>
                <g class="loader-g3">
                    <image href="https://assets.codepen.io/16327/flair-4.png" mask="url(#m3)"/>
                </g>
                <mask id="m3" fill="#fff">
                    <rect x="0" y="0" width="124" height="124"/><rect x="124" y="0" width="124" height="124"/>
                    <rect x="0" y="124" width="124" height="124"/><rect x="124" y="124" width="124" height="124"/>
                </mask>
            </svg>
        </div>

        <div id="main-wrapper" class="opacity-0">
            <navbar class="relative flex items-center px-8 mt-5 md:px-24">
                <div id="nav-actions" class="flex items-center gap-4">
                    <!-- Dinamis: Tombol Login atau Info User -->
                </div>
                <img src="/images/letermark-uin.png" class="ml-auto w-32" alt="Logo PIH" />
            </navbar>

            <section id="home" class="relative h-screen flex flex-col justify-start pt-32 mt-10 px-8 md:px-24 overflow-hidden">
                <div id="cursor-trail-container" class="pointer-events-none absolute inset-0 z-0">
                    {Array.from({ length: 6 }).map((_, i) => (
                        <div class="trail-dot w-4 h-4 bg-yellow-500/30 rounded-full blur-sm"></div>
                    ))}
                </div>
                
                <h1 class="text-[9.5vw] font-[900] leading-[0.85] tracking-tighter pointer-events-none z-10 text-white">
                    <div class="overflow-hidden">
                        <span id="line-1" class="block">Welcome<span class="italic-text ml-2">to</span></span>
                    </div>
                    <div class="overflow-hidden">
                        <span id="line-2" class="block">Life at PIH.</span>
                    </div>
                </h1>

                <!-- Tombol CTA Dinamis -->
                <div id="cta-container" class="mt-12 z-20 flex gap-4 opacity-0">
                    <!-- Dinamis: Mulai Sekarang atau Dashboard -->
                </div>

                <div id="scroll-hint" class="m-auto z-10 opacity-0">
                    <p class="text-[14px] font-bold tracking-[0.4em] uppercase text-white/50 flex flex-col items-center gap-4">
                        Scroll to continue 
                        <span class="w-[1px] h-12 bg-white/30 block"></span> 
                    </p>
                </div>
            </section>

            <section id="introduction" class="min-h-[70vh] py-20 px-8 md:px-24 flex flex-col items-center justify-center">
                <div class="max-w-5xl">
                    <h2 id="intro-text" class="text-white text-4xl md:text-6xl font-light leading-tight tracking-tight uppercase text-center">
                        Step into the dynamic world of communication and creativity at PIH UIN Jakarta.
                    </h2>
                </div>
            </section>

            <section id="teams" class="py-32 mt-40">
                <div class="px-8 md:px-24 mb-20">
                    <h2 class="text-6xl md:text-8xl font-black tracking-tighter uppercase leading-none text-white">
                        Discover <br/> Your Team
                    </h2>
                    <div class="w-20 h-2 bg-white mt-8"></div>
                </div>
                <ul class="w-full m-0 p-0 border-t border-white/20 grid grid-cols-1 md:grid-cols-2">
                    {[
                        { role: "Project Manager", cat: "Strategic", icon: "📈" },
                        { role: "Videografer", cat: "Production", icon: "🎬" },
                        { role: "Photografer", cat: "Production", icon: "📸" },
                        { role: "Graphic Designer", cat: "Creative", icon: "🎨" },
                        { role: "Journalist", cat: "Content", icon: "✍️" },
                        { role: "Public Relation", cat: "Communication", icon: "📢" },
                        { role: "Social Media Optimization", cat: "Communication", icon: "📱" },
                        { role: "Editorial and Publish Management", cat: "Operational", icon: "📅" },
                        { role: "Finance", cat: "Operational", icon: "💰" },
                    ].map((item) => (
                        <li class="role-list-item px-8 md:px-24 py-5 relative flex items-center justify-between group md:border-r border-white/20">
                            <div class="swipe-image">{item.icon}</div>
                            <div class="z-10">
                                <span class="text-[10px] font-bold tracking-[0.4em] text-white/60 uppercase">{item.cat}</span>
                                <h2 class="role-title text-3xl md:text-4xl font-light tracking-tight uppercase mt-2 text-white leading-tight">{item.role}</h2>
                            </div>
                        </li>
                    ))}
                </ul>
                <div class="px-8 md:px-24 mb-20 mt-10">
                    <a href="/teams" class="text-2xl text-white hover:text-white/70 transition-colors duration-300 border-b border-white/20 pb-1">
                        Find out more about roles &rarr;
                    </a>
                </div>
            </section>
            
            <section>
                <svg class="shape-overlays" viewBox="0 0 100 100" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id="gradient1" x1="0%" y1="0%" x2="0%" y2="100%">
                            <stop offset="0%" stop-color="#1b509b"/><stop offset="100%" stop-color="#000000"/>
                        </linearGradient>
                        <linearGradient id="gradient2" x1="0%" y1="0%" x2="0%" y2="100%">
                            <stop offset="0%" stop-color="#0f2854"/><stop offset="100%" stop-color="#1b509b"/>
                        </linearGradient>
                    </defs>
                    <path class="shape-overlays__path" fill="url(#gradient2)"></path>
                    <path class="shape-overlays__path" fill="url(#gradient1)"></path>
                </svg>
            </section>

            <section id="footer-section" class="min-h-[70vh] py-40 px-8 md:px-24 flex flex-col items-center justify-center">
                <div class="max-w-xl">
                    <h2 class="text-white text-4xl md:text-6xl font-light leading-tight tracking-tight uppercase text-center">
                        Ready to Start Your Journey with Us?
                    </h2>
                </div>
            </section>

            <footer id="footer" class="py-20 bg-black text-center border-t border-white/10">
                <p class="text-[10px] tracking-[0.5em] uppercase text-white/40">© 2026 PIH UIN Jakarta</p>
            </footer>
        </div>

        <nav class="dock-wrapper">
            <ul class="toolbar">
                <li class="toolbarItem">
                    <a class="toolbarLink" href="/">
                        <span class="tooltip">Home</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    </a>
                </li>
                <li class="toolbarItem">
                    <a class="toolbarLink protected-link" href="/teams">
                        <span class="tooltip">Hall of Fame</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </a>
                </li>
                <li class="toolbarItem">
                    <a class="toolbarLink protected-link" href="/dashboard">
                        <span class="tooltip">Status</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    </a>
                </li>
                <li class="toolbarItem">
                    <a class="toolbarLink protected-link" href="/internal">
                        <span class="tooltip">Guidelines</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><circle cx="12" cy="12" r="4"/></svg>
                    </a>
                </li>
            </ul>
        </nav>

        <script>
            import { supabase } from '../lib/supabase';
            import { gsap } from "gsap";
            import { ScrollTrigger } from "gsap/ScrollTrigger";
            // @ts-ignore
            import { SplitText } from "gsap/SplitText";

            gsap.registerPlugin(ScrollTrigger, SplitText);

            const navActions = document.getElementById('nav-actions');
            const ctaContainer = document.getElementById('cta-container');
            let currentUser: any = null;

            // FUNGSI LOGIN GOOGLE LANGSUNG
            async function handleGoogleLogin() {
                try {
                    const { error } = await supabase.auth.signInWithOAuth({
                        provider: 'google',
                        options: {
                            redirectTo: window.location.origin
                        }
                    });
                    if (error) throw error;
                } catch (error: any) {
                    console.error("Login Error:", error.message);
                }
            }

            function renderAuthUI(user: any) {
                currentUser = user;
                if (!navActions || !ctaContainer) return;

                if (user) {
                    navActions.innerHTML = `
                        <div class="flex items-center gap-3 bg-white/10 backdrop-blur-md px-4 py-2 rounded-full border border-white/20">
                            <span class="text-[10px] font-bold tracking-widest uppercase opacity-70">${user.user_metadata.full_name || 'User'}</span>
                            <div class="w-1 h-1 bg-green-400 rounded-full animate-pulse"></div>
                        </div>
                    `;
                    ctaContainer.innerHTML = `
                        <a href="/dash" class="auth-btn bg-white text-[#1b509b] px-10 py-4 rounded-2xl font-black text-sm uppercase tracking-widest no-underline">Dashboard</a>
                        <a href="/join" class="auth-btn bg-transparent border-2 border-white/30 text-white px-10 py-4 rounded-2xl font-black text-sm uppercase tracking-widest hover:border-white transition-colors no-underline">Daftar Intern</a>
                    `;
                } else {
                    navActions.innerHTML = `
                        <button id="login-nav" class="text-[10px] font-bold tracking-[0.4em] uppercase text-white hover:opacity-70 bg-transparent border-none cursor-pointer">Login Portal</button>
                    `;
                    ctaContainer.innerHTML = `
                        <button id="login-hero" class="auth-btn bg-white text-[#1b509b] px-10 py-4 rounded-2xl font-black text-sm uppercase tracking-widest border-none">Mulai Sekarang</button>
                    `;

                    // Tambahkan event listener ke tombol baru setelah dirender
                    document.getElementById('login-nav')?.addEventListener('click', handleGoogleLogin);
                    document.getElementById('login-hero')?.addEventListener('click', handleGoogleLogin);
                }
                
                // Animasikan CTA setelah diisi
                gsap.to(ctaContainer, { opacity: 1, y: 0, duration: 1, delay: 0.5, ease: "power4.out" });
            }

            // Monitor status login
            supabase.auth.onAuthStateChange((event, session) => {
                renderAuthUI(session?.user ?? null);
            });

            // INTERCEPTOR UNTUK TOOLBAR
            document.querySelector('.toolbar')?.addEventListener('click', (e) => {
                const target = e.target as HTMLElement;
                const link = target.closest('.toolbarLink');
                
                // Jika user mengklik "Status" atau icon di dalamnya dan belum login
                if (link && (link.getAttribute('href') === '/dash' || link.classList.contains('protected-link')) && !currentUser) {
                    e.preventDefault(); // Batalkan navigasi ke page dash
                    handleGoogleLogin(); // Munculkan popup login
                }
            });

            // --- GSAP ANIMATIONS & LOADER ---
            function initLoader() {
                const tl = gsap.timeline({
                    onComplete: () => {
                        gsap.to("#loader", { opacity: 0, duration: 0.4, pointerEvents: "none" });
                        gsap.to("#main-wrapper", { opacity: 1, duration: 1 });
                        init(); 
                    }
                });

                gsap.set('#svg-loader', { opacity: 1 });
                tl.fromTo('.loader-g1', {scale:0.1, transformOrigin:'124 124'}, {duration:0.35, scale:1, ease:'expo.inOut'})
                  .to('.loader-g1', {duration:1.2, rotate:15, ease:'none'}, 0.1)
                  .to('.loader-g1 image', {scale:(i:any)=>[0.4,0.2,0.3][i], x:(i:any)=>[0,135,100][i], y:(i:any)=>[90,24,124][i], ease:'back'}, 0.4)
                  .to('.loader-g1 image', {duration:0.01, opacity:0, stagger:0.06}, 1.1)
                  .to('#m2 circle', {duration:0.4, attr:{r:"124"}, ease:'circ'}, 1.3)
                  .fromTo('.loader-g2', {scale:1, transformOrigin:'124 124'}, {duration:1, scale:0.9, ease:'none'}, 1.3)
                  .to('#m2 circle', {duration:0.3, attr:{cx:(i:any)=>["+=248","-=248"][i]}, ease:'sine.in'}, 2.1)
                  .fromTo('.loader-g3', {transformOrigin:'124 124', rotate:-90}, {duration:0.7, rotate:0, ease:'expo'}, 2.3)
                  .fromTo('#m3 rect', {transformOrigin:(i:any)=>['0 124','124 0','124 124','248 124'][i], scale:0},{duration:0.4, scale:1, ease:'expo', stagger:-0.03}, 2.3);
            }

            function init() {
                const hero = document.querySelector("#home") as HTMLElement;
                const dots = document.querySelectorAll(".trail-dot");
                if (hero && dots.length > 0) {
                    const xTo = Array.from(dots).map(dot => gsap.quickTo(dot, "x", { duration: 0.4, ease: "power3" }));
                    const yTo = Array.from(dots).map(dot => gsap.quickTo(dot, "y", { duration: 0.4, ease: "power3" }));
                    hero.addEventListener("mousemove", (e) => {
                        dots.forEach((_, i) => {
                            gsap.to({}, { onUpdate: () => { xTo[i](e.clientX - 8); yTo[i](e.clientY - 8); }, delay: i * 0.02 });
                        });
                    });
                }

                gsap.to("#scroll-hint", { opacity: 1, duration: 1, delay: 1 });

                const scrollTl = gsap.timeline({ scrollTrigger: { trigger: "#home", start: "top top", end: "+=120%", scrub: 1, pin: true } });
                scrollTl.to("#line-1", { y: 100, opacity: 0 })
                        .to("#line-2", { y: 200, opacity: 0 }, "-=0.6")
                        .to("#cta-container", { y: 50, opacity: 0 }, "-=0.8")
                        .to("#scroll-hint", { opacity: 0, y: 20 }, "-=0.8");

                function createTextAnimation(targetId: string, triggerId: string) {
                    const split = new SplitText(targetId, { type: "words" });
                    gsap.from(split.words, {
                        opacity: 0, y: 50, rotateX: -45, transformOrigin: "50% 50%", stagger: 0.1, duration: 1.2, ease: "power4.out",
                        scrollTrigger: { trigger: triggerId, start: "top 80%", end: "bottom 20%", toggleActions: "play reverse play reverse" }
                    });
                }

                createTextAnimation("#intro-text", "#introduction");
                createTextAnimation("#footer-section", "#footer-section");

                gsap.utils.toArray(".role-list-item").forEach((el: any) => {
                    const image = el.querySelector(".swipe-image");
                    if (!image) return;
                    const setX = gsap.quickTo(image, "x", { duration: 0.4, ease: "power3" });
                    const setY = gsap.quickTo(image, "y", { duration: 0.4, ease: "power3" });
                    const align = (e: MouseEvent) => { setX(e.clientX); setY(e.clientY); };
                    const fade = gsap.to(image, { autoAlpha: 1, duration: 0.3, paused: true });
                    el.addEventListener("mouseenter", (e: MouseEvent) => { fade.play(); document.addEventListener("mousemove", align); align(e); });
                    el.addEventListener("mouseleave", () => { fade.reverse(); document.removeEventListener("mousemove", align); });
                });

                const dock = document.querySelector(".toolbar") as HTMLElement;
                const icons = document.querySelectorAll(".toolbarItem");
                if (dock && icons.length > 0) {
                    const min = 48; const max = 100; const bound = min * Math.PI;
                    gsap.set(icons, { transformOrigin: "50% 120%", height: 40 });
                    dock.addEventListener("mousemove", (event: MouseEvent) => {
                        const rect = dock.getBoundingClientRect();
                        const firstIcon = icons[0] as HTMLElement;
                        const offset = rect.left + firstIcon.offsetLeft;
                        const pointer = event.clientX - offset;
                        icons.forEach((icon, i) => {
                            const distance = (i * min + min / 2) - pointer;
                            let x = 0, scale = 1;
                            if (Math.abs(distance) < bound) {
                                const rad = distance / min * 0.5;
                                scale = 1 + (max / min - 1) * Math.cos(rad);
                                x = 2 * (max - min) * Math.sin(rad);
                            } else { x = (distance < 0 ? 2 : -2) * (max - min); }
                            gsap.to(icon, { duration: 0.3, x: x, scale: scale, ease: "power3.out" });
                        });
                    });
                    dock.addEventListener("mouseleave", () => gsap.to(icons, { duration: 0.3, scale: 1, x: 0 }));
                }

                initOverlays(); 
            }

            function initOverlays() {
                const paths = document.querySelectorAll(".shape-overlays__path");
                const numPoints = 10;
                const numPaths = paths.length;
                const delayPointsMax = 0.3;
                const delayPerPath = 0.25;
                const allPoints: number[][] = []; 

                for (let i = 0; i < numPaths; i++) {
                    let points: number[] = []; 
                    allPoints.push(points);
                    for (let j = 0; j < numPoints; j++) { points.push(100); }
                }

                function render() {
                    for (let i = 0; i < numPaths; i++) {
                        const path = paths[i] as SVGPathElement;
                        const points = allPoints[i];
                        let d = `M 0 100 V ${points[0]} C`; 
                        for (let j = 0; j < numPoints - 1; j++) {
                            let p = (j + 1) / (numPoints - 1) * 100;
                            let cp = p - (1 / (numPoints - 1) * 100) / 2;
                            d += ` ${cp} ${points[j]} ${cp} ${points[j+1]} ${p} ${points[j+1]}`;
                        }
                        d += ` V 100 H 0`;
                        path.setAttribute("d", d);
                    }
                }

                const animateOverlay = (targetValue: number) => {
                    const tl = gsap.timeline({ onUpdate: render });
                    const pointsDelay = Array.from({length: numPoints}, () => Math.random() * delayPointsMax);
                    for (let i = 0; i < numPaths; i++) {
                        const points = allPoints[i];
                        const pathDelay = delayPerPath * i;
                        for (let j = 0; j < numPoints; j++) {
                            tl.to(points, { [j]: targetValue, duration: 0.9, ease: "power2.inOut" }, pointsDelay[j] + pathDelay);
                        }
                    }
                };

                ScrollTrigger.create({
                    trigger: "#footer",
                    start: "top 80%", 
                    onEnter: () => animateOverlay(0),
                    onLeaveBack: () => animateOverlay(100)
                });
            }

            window.addEventListener("load", initLoader);
        </script>
    </body>
</html>