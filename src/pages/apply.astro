---
import { getCollection } from 'astro:content';
import '../styles/global.css';

// 1. Ambil data lowongan dari Decap CMS
const allVacancies = await getCollection('vacancies');

// 2. Filter hanya lowongan yang "Open" dan pecah (flatten) list role-nya
const availableRoles = allVacancies
  .filter(v => v.data.status === 'Open')
  .flatMap(v => 
    v.data.roles.map(role => ({
      display: `${role.role_title} (${v.data.batch_name})`,
      value: `${role.role_title} - ${v.data.batch_name}`
    }))
  );
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Daftar Intern | Life at PIH</title>
    <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Funnel Display', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen">
    <main class="max-w-2xl mx-auto py-16 px-6">
        <div class="bg-white p-10 rounded-[2.5rem] border border-slate-200 shadow-2xl shadow-blue-900/10">
            <h1 class="text-3xl font-extrabold text-slate-900 mb-2">Formulir Intern</h1>
            <p class="text-slate-500 mb-8 italic text-sm">Silakan pilih posisi yang tersedia di bawah ini.</p>
            
            <form id="apply-form" class="space-y-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-widest text-[10px]">Posisi Magang</label>
                    <select id="role_applied" required class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 focus:ring-2 focus:ring-[#1b509b] outline-none appearance-none font-bold text-slate-700">
                        <option value="" disabled selected>-- Pilih Posisi --</option>
                        {availableRoles.length > 0 ? (
                            availableRoles.map((role) => (
                                <option value={role.value}>{role.display}</option>
                            ))
                        ) : (
                            <option disabled>Tidak ada lowongan tersedia</option>
                        )}
                    </select>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-[10px] font-bold text-slate-700 mb-2 uppercase tracking-widest">Nama Lengkap</label>
                        <input type="text" id="full_name" required class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 focus:ring-2 focus:ring-[#1b509b] outline-none" placeholder="Sesuai KTP">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-slate-700 mb-2 uppercase tracking-widest">Jurusan</label>
                        <input type="text" id="major" required class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 focus:ring-2 focus:ring-[#1b509b] outline-none" placeholder="Contoh: Informatika">
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-bold text-slate-700 mb-2 uppercase tracking-widest">Link CV & Portfolio</label>
                    <input type="url" id="portfolio_url" required class="w-full px-5 py-4 rounded-2xl border border-slate-200 bg-slate-50 focus:ring-2 focus:ring-[#1b509b] outline-none" placeholder="https://drive.google.com/...">
                </div>

                <button type="submit" id="submit-btn" class="w-full bg-[#1b509b] text-white font-extrabold py-5 rounded-2xl shadow-lg shadow-blue-900/30 hover:bg-blue-800 transition-all transform active:scale-95">
                    Kirim Lamaran Sekarang
                </button>
            </form>
        </div>
    </main>

    <script>
        import { supabase } from '../lib/supabase';

        const form = document.getElementById('apply-form') as HTMLFormElement | null;
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!submitBtn) return;

            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="animate-pulse">Mengirim...</span>`;

            const { data: { user } } = await supabase.auth.getUser();

            if (!user) {
                alert("Anda harus login terlebih dahulu.");
                window.location.href = '/login';
                return;
            }

            const formData = {
                user_id: user.id,
                user_email: user.email,
                full_name: (document.getElementById('full_name') as HTMLInputElement).value,
                major: (document.getElementById('major') as HTMLInputElement).value,
                role_applied: (document.getElementById('role_applied') as HTMLSelectElement).value,
                portfolio_url: (document.getElementById('portfolio_url') as HTMLInputElement).value,
                status: 'administrasi'
            };

            const { error } = await supabase
                .from('applications')
                .insert([formData]);

            if (error) {
                alert("Terjadi kesalahan: " + error.message);
                submitBtn.disabled = false;
                submitBtn.innerText = "Kirim Lamaran Sekarang";
            } else {
                window.location.href = '/dashboard';
            }
        });
    </script>
</body>
</html>