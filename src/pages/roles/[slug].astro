---
export const prerender = true; // KRUSIAL: Memastikan halaman dibangun saat build-time untuk mencegah error 500 di Cloudflare
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  // Menggunakan 'as any' untuk fleksibilitas koleksi konten
  const roles = await getCollection('roles' as any);
  return roles.map((entry: any) => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{entry.data.title} | Life at PIH</title>
    <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:ital,wght@0,300;0,800;1,300&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style is:global>
        :root {
            --pih-blue: #1b509b;
            --pih-dark: #0f2854;
        }
        body { 
            font-family: 'Funnel Display', sans-serif; 
            background-color: var(--pih-dark); 
            color: white; 
            margin: 0;
        }
        
        /* Tipografi untuk konten Markdown */
        .prose h1, .prose h2, .prose h3 { 
            color: white !important; 
            font-weight: 800 !important; 
            text-transform: uppercase; 
            letter-spacing: -0.02em; 
            margin-top: 2rem !important;
        }
        .prose p, .prose li { 
            color: rgba(255,255,255,0.7) !important; 
            line-height: 1.8; 
            font-size: 1.1rem;
        }
        .prose strong { color: #facc15 !important; }
        .prose ul { list-style-type: disc; padding-left: 1.5rem; }
        
        /* Modal Popup Styling */
        #auth-modal {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 10001;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: rgba(15, 40, 84, 0.4);
            backdrop-filter: blur(8px);
        }
        .modal-content {
            background: rgba(255, 255, 255, 0.95);
            color: #0f2854;
            padding: 40px;
            border-radius: 32px;
            max-width: 400px;
            width: 100%;
            text-align: center;
            box-shadow: 0 30px 60px rgba(0,0,0,0.3);
            transform: scale(0.9);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        #auth-modal.active { display: flex; }
        #auth-modal.active .modal-content { transform: scale(1); opacity: 1; }
    </style>
</head>
<body class="antialiased selection:bg-yellow-400 selection:text-black">

    <!-- Custom Auth Popup (Konsisten dengan Index) -->
    <div id="auth-modal">
        <div class="modal-content">
            <div class="w-16 h-16 bg-[#1b509b] text-white rounded-2xl flex items-center justify-center mx-auto mb-6 text-2xl shadow-lg">🔒</div>
            <h3 class="text-2xl font-black uppercase tracking-tight mb-2">Akses Terbatas</h3>
            <p class="text-slate-500 font-medium mb-8 leading-relaxed">Silakan Login atau Registrasi terlebih dahulu untuk mendaftar posisi ini.</p>
            <div class="flex flex-col gap-3">
                <button id="modal-login-btn" class="bg-[#1b509b] text-white py-4 rounded-xl font-bold uppercase tracking-widest text-xs hover:bg-blue-800 transition-colors">Login Sekarang</button>
                <button id="modal-close-btn" class="bg-slate-100 text-slate-400 py-3 rounded-xl font-bold uppercase tracking-widest text-[10px] hover:bg-slate-200 transition-colors">Mungkin Nanti</button>
            </div>
        </div>
    </div>

    <main class="max-w-4xl mx-auto py-20 px-8">
        <a href="/" class="text-white/30 no-underline text-[10px] font-black uppercase tracking-[0.3em] hover:text-white transition-colors group flex items-center gap-2">
            <span class="group-hover:-translate-x-1 transition-transform inline-block">←</span> Kembali ke Beranda
        </a>
        
        <div class="mt-20">
            <div class="flex flex-col md:flex-row md:items-center gap-8 mb-12">
                <div class="w-24 h-24 bg-white/5 rounded-3xl flex items-center justify-center text-5xl border border-white/10 shadow-inner">
                    {entry.data.icon}
                </div>
                <div>
                    <span class="text-blue-400 font-black uppercase tracking-[0.4em] text-[10px]">{entry.data.category}</span>
                    <h1 class="text-5xl md:text-7xl font-black italic uppercase tracking-tighter mt-1 leading-none">{entry.data.title}</h1>
                </div>
            </div>
            
            <div class="bg-white/5 border border-white/10 p-8 rounded-[2rem] backdrop-blur-sm">
                <p class="text-xl text-white/80 leading-relaxed italic font-light">"{entry.data.description}"</p>
            </div>
        </div>

        <div class="mt-16 prose prose-invert prose-blue max-w-none border-t border-white/10 pt-16">
            <Content />
        </div>

        <!-- Section CTA (Call to Action) -->
        <div class="mt-24 bg-white rounded-[2.5rem] p-12 text-center shadow-2xl">
            <h3 class="text-[#0f2854] text-3xl font-black uppercase italic mb-4 leading-tight">Siap Berkontribusi di Posisi Ini?</h3>
            <p class="text-slate-500 mb-10 max-w-md mx-auto font-medium">Klik tombol di bawah untuk mengisi formulir pendaftaran Batch yang sedang dibuka.</p>
            <a id="apply-role-btn" href="/join" class="inline-block bg-[#1b509b] text-white px-12 py-5 rounded-2xl font-black uppercase tracking-widest text-sm hover:scale-105 transition-transform shadow-xl shadow-blue-900/30 no-underline">
                Daftar Sekarang
            </a>
        </div>
        
        <footer class="mt-32 text-center opacity-20 text-[9px] font-black uppercase tracking-[0.5em]">
            © 2026 PIH UIN Syarif Hidayatullah Jakarta
        </footer>
    </main>

    <script>
        import { supabase } from '../../lib/supabase';

        const applyBtn = document.getElementById('apply-role-btn');
        const authModal = document.getElementById('auth-modal');
        const modalCloseBtn = document.getElementById('modal-close-btn');
        const modalLoginBtn = document.getElementById('modal-login-btn');

        // Fungsi pengecekan login
        async function checkAuth() {
            const { data: { user } } = await supabase.auth.getUser();
            return user;
        }

        applyBtn?.addEventListener('click', async (e) => {
            const user = await checkAuth();
            if (!user) {
                e.preventDefault(); // Mencegah pindah halaman ke /join
                authModal?.classList.add('active');
            }
        });

        modalCloseBtn?.addEventListener('click', () => authModal?.classList.remove('active'));
        
        modalLoginBtn?.addEventListener('click', async () => {
            authModal?.classList.remove('active');
            await supabase.auth.signInWithOAuth({
                provider: 'google',
                options: { redirectTo: window.location.href }
            });
        });
    </script>
</body>
</html>