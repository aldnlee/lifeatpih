---
import '../styles/global.css';
import { getCollection } from 'astro:content';

// 0. Definisi Interface untuk Type Safety
interface Role {
  role_title: string;
  description?: string;
}

// 1. Ambil data dari content collection vacancies
const allBatches = await getCollection('vacancies' as any);

// 2. Cari batch yang statusnya "Open" (Case-Insensitive & Trim untuk keamanan)
const activeBatch = allBatches.find((b: any) => {
    const status = (b.data.status || "").toLowerCase().trim();
    return status === 'open';
}) as any;

// 3. Validasi: Apakah ada batch yang buka?
const isAnyOpen = !!activeBatch;

// 4. Ambil roles dan data batch dengan safety check
const availableRoles: Role[] = activeBatch?.data?.roles || [];
const currentBatchName = activeBatch?.data?.batch_name || "Join the Squad";
const currentBatchId = activeBatch?.data?.batch_id || "unspecified";

// Format roles untuk Select Option
const roleOptions = availableRoles.map((role: Role) => ({
    display: `${role.role_title} (${currentBatchName})`,
    value: `${role.role_title} - ${currentBatchName}`
}));
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{currentBatchName} | Life at PIH</title>
    <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style is:global>
        :root { 
            --pih-blue: #1b509b; 
            --pih-dark: #0f2854; 
            --white: #ffffff;
        }
        
        body { 
            font-family: 'Funnel Display', sans-serif; 
            background: var(--pih-blue); 
            color: white; 
            margin: 0; 
            overflow-x: hidden; 
        }

        header { padding: 60px 20px; text-align: center; }
        .main-title { font-size: 8vw; font-weight: 800; line-height: 0.8; letter-spacing: -0.05em; margin: 0; text-transform: uppercase; }
        .sub-title { font-size: 1.2rem; opacity: 0.6; margin-top: 10px; font-weight: 300; letter-spacing: 0.1em; }

        .form-wrapper { max-width: 800px; margin: 0 auto; padding: 0 20px 180px 20px; }

        .status-badge {
            display: inline-block;
            padding: 6px 16px;
            border-radius: 100px;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 24px;
        }
        .status-open { background: #4ade80; color: #064e3b; }
        .status-closed { background: #f87171; color: #7f1d1d; }

        .closed-state {
            text-align: center;
            padding: 80px 40px;
            border: 1px dashed rgba(255,255,255,0.2);
            border-radius: 32px;
            background: rgba(255,255,255,0.02);
            backdrop-filter: blur(10px);
        }

        .registration-container {
            border: 1px solid rgba(255,255,255,0.2);
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            padding: 40px;
            border-radius: 32px;
        }

        input, select {
            background: rgba(255, 255, 255, 0.1) !important;
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
            color: white !important;
            transition: all 0.3s ease;
        }

        input:focus, select:focus {
            background: rgba(255, 255, 255, 0.15) !important;
            border-color: white !important;
            outline: none;
        }

        option { background: var(--pih-dark); color: white; }

        /* DOCK STYLES */
        .dock-wrapper { position: fixed; bottom: 25px; left: 50%; transform: translateX(-50%); display: flex; justify-content: center; z-index: 1000; }
        .toolbar { display: inline-flex; justify-content: center; align-items: center; height: 65px; border-radius: 22px; padding: 0 15px; background-color: rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); list-style: none; border: 1px solid rgba(255, 255, 255, 0.2); box-shadow: 0 20px 40px rgba(0,0,0,0.3); margin: 0; }
        .toolbarItem { width: 45px; height: 45px; margin: 0 6px; position: relative; display: flex; align-items: center; justify-content: center; }
        .toolbarLink { display: flex; height: 100%; width: 100%; text-decoration: none; align-items: center; justify-content: center; background: white; border-radius: 12px; color: var(--pih-dark); transition: transform 0.3s ease, background 0.3s ease; }
        .tooltip { position: absolute; top: -45px; left: 50%; transform: translateX(-50%); background: white; color: black; padding: 5px 12px; border-radius: 8px; font-size: 11px; font-weight: bold; opacity: 0; transition: opacity 0.2s; white-space: nowrap; pointer-events: none; box-shadow: 0 5px 15px rgba(0,0,0,0.2); }
        .toolbarItem:hover .tooltip { opacity: 1; }
    </style>
</head>
<body>

    <header>
        <h1 class="main-title">Join The <br/><span style="font-style: italic; font-weight: 300;">Squad</span></h1>
        <p class="sub-title">BE PART OF PIH UIN JAKARTA</p>
    </header>

    <main class="form-wrapper">
        <a href="/" style="display: inline-block; color: white; text-decoration: none; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; margin-bottom: 30px; opacity: 0.5; transition: 0.3s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.5'">
            ← Back to Home
        </a>

        {isAnyOpen ? (
            <div>
                <div class="status-badge status-open">Recruitment Open</div>
                
                <div class="registration-container">
                    <input type="hidden" id="batch_id_val" value={currentBatchId} />
                    
                    <form id="apply-form" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-[10px] font-bold uppercase tracking-widest mb-2 opacity-60">Nama Lengkap</label>
                                <input type="text" id="full_name" required class="w-full px-5 py-4 rounded-2xl" placeholder="Sesuai KTP">
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold uppercase tracking-widest mb-2 opacity-60">Jurusan</label>
                                <input type="text" id="major" required class="w-full px-5 py-4 rounded-2xl" placeholder="Contoh: Informatika">
                            </div>
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest mb-2 opacity-60">Posisi Magang</label>
                            <select id="role_applied" required class="w-full px-5 py-4 rounded-2xl appearance-none">
                                <option value="" disabled selected>-- Pilih Posisi --</option>
                                {roleOptions.map((role) => (
                                    <option value={role.value}>{role.display}</option>
                                ))}
                            </select>
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest mb-2 opacity-60">Link CV & Portofolio</label>
                            <input type="url" id="portfolio_url" required class="w-full px-5 py-4 rounded-2xl" placeholder="https://drive.google.com/...">
                        </div>

                        <button type="submit" id="submit-btn" class="w-full bg-white text-[#1b509b] font-black py-5 rounded-2xl shadow-xl hover:scale-[1.02] transition-transform active:scale-95 uppercase tracking-widest text-sm">
                            Kirim Lamaran Sekarang
                        </button>
                    </form>
                </div>
                
                <div class="mt-12 text-center opacity-40">
                    <p class="text-[10px] uppercase font-bold tracking-[0.3em] mb-4">Posisi Tersedia:</p>
                    <div class="flex flex-wrap justify-center gap-3">
                        {availableRoles.map((r: Role) => (
                            <span class="text-[11px] border border-white/30 px-4 py-1.5 rounded-full">{r.role_title}</span>
                        ))}
                    </div>
                </div>
            </div>
        ) : (
            <div class="closed-state">
                <div class="status-badge status-closed">Registration Closed</div>
                <h2 class="text-3xl font-black uppercase tracking-tighter mb-4">Pendaftaran Ditutup</h2>
                <p class="text-white/50 text-sm max-w-md mx-auto leading-relaxed font-light">
                    Mohon maaf, saat ini sedang tidak ada lowongan magang yang tersedia. 
                    Pantau terus media sosial kami untuk informasi Batch selanjutnya.
                </p>
                {allBatches.length > 0 && (
                    <p class="text-[9px] mt-10 text-white/10 uppercase tracking-widest">
                        Debug: {allBatches.length} file terdeteksi di GitHub, tapi tidak ada yang berstatus 'Open'.
                    </p>
                )}
            </div>
        )}
    </main>

    <nav class="dock-wrapper">
        <ul class="toolbar">
            <li class="toolbarItem">
                <a class="toolbarLink" href="/">
                    <span class="tooltip">Home</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </a>
            </li>
            <li class="toolbarItem">
                <a class="toolbarLink" href="/teams">
                    <span class="tooltip">Hall of Fame</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </a>
            </li>
            <li class="toolbarItem">
                <a class="toolbarLink" href="/join" style="background: var(--pih-dark); color: white;">
                    <span class="tooltip">Register</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="16" y1="11" x2="22" y2="11"/></svg>
                </a>
            </li>
            <li class="toolbarItem">
                <a class="toolbarLink" href="/internal">
                    <span class="tooltip">Guidelines</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><circle cx="12" cy="12" r="4"/></svg>
                </a>
            </li>
        </ul>
    </nav>

    <script>
        import { gsap } from "gsap";
        import { supabase } from '../lib/supabase';

        // --- 1. DOCK ANIMATION ---
        const dock = document.querySelector(".toolbar") as HTMLElement;
        const icons = document.querySelectorAll(".toolbarItem");
        if (dock && icons.length > 0) {
            const firstIcon = icons[0] as HTMLElement;
            const min = 48; const max = 100; const bound = min * Math.PI;
            gsap.set(icons, { transformOrigin: "50% 120%", height: 40 });
            dock.addEventListener("mousemove", (event: MouseEvent) => {
                const rect = dock.getBoundingClientRect();
                const offset = rect.left + firstIcon.offsetLeft;
                const pointer = event.clientX - offset;
                icons.forEach((icon, i) => {
                    const distance = (i * min + min / 2) - pointer;
                    let x = 0, scale = 1;
                    if (Math.abs(distance) < bound) {
                        const rad = distance / min * 0.5;
                        scale = 1 + (max / min - 1) * Math.cos(rad);
                        x = 2 * (max - min) * Math.sin(rad);
                    } else { x = (distance < 0 ? 2 : -2) * (max - min); }
                    gsap.to(icon, { duration: 0.3, x: x, scale: scale, ease: "power3.out" });
                });
            });
            dock.addEventListener("mouseleave", () => gsap.to(icons, { duration: 0.3, scale: 1, x: 0 }));
        }

        // --- 2. SUPABASE SUBMISSION LOGIC ---
        const form = document.getElementById('apply-form') as HTMLFormElement | null;
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
        const batchIdInput = document.getElementById('batch_id_val') as HTMLInputElement | null;

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!submitBtn) return;

            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="animate-pulse uppercase tracking-widest text-[10px]">Mengirim Lamaran...</span>`;

            const { data: { user } } = await supabase.auth.getUser();

            if (!user) {
                alert("Sesi berakhir. Silakan login kembali melalui halaman utama.");
                window.location.href = '/';
                return;
            }

            const formData = {
                user_id: user.id,
                user_email: user.email,
                full_name: (document.getElementById('full_name') as HTMLInputElement).value,
                major: (document.getElementById('major') as HTMLInputElement).value,
                role_applied: (document.getElementById('role_applied') as HTMLSelectElement).value,
                portfolio_url: (document.getElementById('portfolio_url') as HTMLInputElement).value,
                batch_id: batchIdInput?.value || "unspecified", 
                status: 'administrasi'
            };

            const { error } = await supabase
                .from('applications')
                .insert([formData]);

            if (error) {
                alert("Terjadi kesalahan database: " + error.message);
                submitBtn.disabled = false;
                submitBtn.innerText = "Kirim Lamaran Sekarang";
            } else {
                window.location.href = '/dashboard';
            }
        });
    </script>
</body>
</html>