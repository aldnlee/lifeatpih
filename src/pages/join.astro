---
import '../styles/global.css';
import { getCollection } from 'astro:content';

// 0. Definisi Interface untuk Type Safety
interface Role {
  role_title: string;
  description?: string;
}

// 1. Ambil data dari content collection vacancies
const allBatches = await getCollection('vacancies' as any);

/**
 * 2. PENCARIAN BATCH AKTIF
 */
const activeBatch = allBatches.find((b: any) => {
    const d = b.data?.map ? b.data.map : b.data;
    const status = (d?.status || "").toLowerCase().trim();
    return status === 'open';
}) as any;

const isAnyOpen = !!activeBatch;
const finalData = activeBatch?.data?.map ? activeBatch.data.map : activeBatch?.data;

const availableRoles: Role[] = finalData?.roles || [];
const currentBatchName = finalData?.batch_name || "Mahardhika Internship";
const currentBatchId = finalData?.batch_id || "unspecified";

// Format roles untuk Select Option
const roleOptions = availableRoles.map((role: Role) => ({
    display: role.role_title,
    value: role.role_title
}));
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Daftar {currentBatchName} | Life at PIH</title>
    <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style is:global>
        :root { 
            --pih-blue: #1b509b; 
            --pih-dark: #0f2854; 
            --white: #ffffff;
        }
        
        body { 
            font-family: 'Funnel Display', sans-serif; 
            background: var(--pih-blue); 
            color: white; 
            margin: 0; 
            overflow-x: hidden; 
        }

        header { padding: 80px 20px 40px 20px; text-align: center; }
        .main-title { font-size: 8vw; font-weight: 800; line-height: 0.8; letter-spacing: -0.05em; margin: 0; text-transform: uppercase; }
        
        .form-wrapper { max-width: 900px; margin: 0 auto; padding: 0 20px 180px 20px; }

        .registration-container {
            border: 1px solid rgba(255,255,255,0.2);
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            padding: 40px;
            border-radius: 40px;
            box-shadow: 0 40px 100px rgba(0,0,0,0.2);
        }

        .form-section-title {
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.3em;
            color: #facc15;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .form-section-title::after { content: ""; flex: 1; height: 1px; background: rgba(255,255,255,0.1); }

        label { display: block; font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; opacity: 0.6; }

        input, select, textarea {
            background: rgba(255, 255, 255, 0.08) !important;
            border: 1px solid rgba(255, 255, 255, 0.15) !important;
            color: white !important;
            width: 100%;
            padding: 18px 24px;
            border-radius: 18px;
            font-size: 15px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        input:focus, select:focus, textarea:focus {
            background: rgba(255, 255, 255, 0.12) !important;
            border-color: rgba(255, 255, 255, 0.5) !important;
            box-shadow: 0 0 0 4px rgba(255,255,255,0.05);
            outline: none;
        }

        option { background: var(--pih-dark); color: white; }

        .btn-submit {
            background: white;
            color: var(--pih-blue);
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            padding: 24px;
            border-radius: 20px;
            width: 100%;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.4s ease;
            border: none;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }
        .btn-submit:hover { transform: translateY(-5px); box-shadow: 0 25px 50px rgba(0,0,0,0.2); background: #f8fafc; }
        .btn-submit:active { transform: scale(0.98); }
        .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

        /* DOCK STYLES */
        .dock-wrapper { position: fixed; bottom: 25px; left: 50%; transform: translateX(-50%); display: flex; justify-content: center; z-index: 1000; }
        .toolbar { display: inline-flex; justify-content: center; align-items: center; height: 65px; border-radius: 22px; padding: 0 15px; background-color: rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); list-style: none; border: 1px solid rgba(255, 255, 255, 0.2); box-shadow: 0 20px 40px rgba(0,0,0,0.3); margin: 0; }
        .toolbarItem { width: 45px; height: 45px; margin: 0 6px; position: relative; display: flex; align-items: center; justify-content: center; }
        .toolbarLink { display: flex; height: 100%; width: 100%; text-decoration: none; align-items: center; justify-content: center; background: white; border-radius: 12px; color: var(--pih-dark); transition: transform 0.3s ease, background 0.3s ease; }
        .toolbarLink:hover { transform: translateY(-5px); background: #f0f0f0; }
        .tooltip { position: absolute; top: -45px; left: 50%; transform: translateX(-50%); background: white; color: black; padding: 5px 12px; border-radius: 8px; font-size: 11px; font-weight: bold; opacity: 0; transition: opacity 0.2s; white-space: nowrap; pointer-events: none; box-shadow: 0 5px 15px rgba(0,0,0,0.2); }
        .toolbarItem:hover .tooltip { opacity: 1; }
    </style>
</head>
<body>

    <header>
        <h1 class="main-title">Apply <br/><span style="font-style: italic; font-weight: 300;">Now</span></h1>
        <p style="opacity: 0.6; margin-top: 15px; letter-spacing: 0.2em; font-weight: 300; text-transform: uppercase;">{currentBatchName}</p>
    </header>

    <main class="form-wrapper">
        <a href="/" style="display: inline-block; color: white; text-decoration: none; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; margin-bottom: 30px; opacity: 0.5; transition: 0.3s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.5'">
            ← Back to Home
        </a>

        {isAnyOpen ? (
            <div class="registration-container">
                <input type="hidden" id="batch_id_val" value={currentBatchId} />
                
                <form id="apply-form" class="space-y-8">
                    
                    <!-- SECTION 1: DATA DIRI -->
                    <div>
                        <div class="form-section-title">Identitas Mahasiswa</div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label>Nama Lengkap</label>
                                <input type="text" id="full_name" required placeholder="Sesuai KTP">
                            </div>
                            <div>
                                <label>Nomor Telp / WhatsApp</label>
                                <input type="tel" id="phone" required placeholder="0812xxxx">
                            </div>
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                            <div>
                                <label>Fakultas</label>
                                <input type="text" id="faculty" required placeholder="Contoh: Sains dan Teknologi">
                            </div>
                            <div>
                                <label>Program Studi</label>
                                <input type="text" id="study_program" required placeholder="Contoh: Teknik Informatika">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                            <div>
                                <label>NIM</label>
                                <input type="text" id="nim" required placeholder="Nomor Induk Mahasiswa">
                            </div>
                            <div>
                                <label>Semester</label>
                                <input type="number" id="semester" required min="1" max="14" placeholder="Contoh: 6">
                            </div>
                        </div>
                    </div>

                    <!-- SECTION 2: KEGIATAN & MINAT -->
                    <div>
                        <div class="form-section-title">Preferensi & Pengalaman</div>
                        <div class="mb-6">
                            <label>Apakah kamu memiliki kegiatan di tempat lain saat ini?</label>
                            <textarea id="other_activities" required rows="3" placeholder="Sebutkan organisasi, magang lain, atau kerja sampingan jika ada..."></textarea>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8 bg-white/5 rounded-[30px] border border-white/10">
                            <div class="space-y-4">
                                <div>
                                    <label class="text-yellow-400">Posisi yang Diminati 1</label>
                                    <select id="role_1" required>
                                        <option value="" disabled selected>-- Pilih Posisi Utama --</option>
                                        {roleOptions.map(r => <option value={r.value}>{r.display}</option>)}
                                    </select>
                                </div>
                                <div>
                                    <label>Alasan Memilih Posisi Tersebut</label>
                                    <textarea id="reason_1" required rows="4" placeholder="Jelaskan ketertarikanmu..."></textarea>
                                </div>
                            </div>

                            <div class="space-y-4">
                                <div>
                                    <label class="text-blue-300">Posisi yang Diminati 2</label>
                                    <select id="role_2" required>
                                        <option value="" disabled selected>-- Pilih Posisi Cadangan --</option>
                                        {roleOptions.map(r => <option value={r.value}>{r.display}</option>)}
                                    </select>
                                </div>
                                <div>
                                    <label>Alasan Memilih Posisi Tersebut</label>
                                    <textarea id="reason_2" required rows="4" placeholder="Jelaskan ketertarikanmu..."></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- SECTION 3: PORTOFOLIO -->
                    <div>
                        <div class="form-section-title">Dokumen Pendukung</div>
                        <label>Lampirkan Tautan CV dan Portfolio</label>
                        <input type="url" id="portfolio_url" required placeholder="https://drive.google.com/share-link-kamu">
                        <p class="text-[10px] opacity-40 mt-2 font-bold uppercase tracking-wider italic">*Pastikan link dapat diakses secara publik</p>
                    </div>

                    <!-- DECLARATION -->
                    <div class="bg-emerald-500/10 border border-emerald-500/20 p-6 rounded-2xl flex items-start gap-4">
                        <input type="checkbox" id="declaration" required class="!w-6 !h-6 mt-1 cursor-pointer accent-emerald-500">
                        <label for="declaration" class="!m-0 !opacity-100 normal-case text-sm leading-relaxed cursor-pointer font-medium">
                            Dengan ini, saya menyatakan data yang saya lampirkan dan saya isi telah sesuai dan benar. Saya bersedia mengikuti seluruh rangkaian seleksi <span class="text-emerald-400 font-bold">{currentBatchName}</span>.
                        </label>
                    </div>

                    <button type="submit" id="submit-btn" class="btn-submit">
                        Kirim Lamaran Sekarang
                    </button>
                </form>
            </div>
        ) : (
            <div class="text-center py-20 px-10 border border-dashed border-white/20 rounded-[40px] bg-white/5 backdrop-blur-xl">
                <div class="text-4xl mb-4">📢</div>
                <h2 class="text-2xl font-black uppercase tracking-tighter">Pendaftaran Belum Dibuka</h2>
                <p class="opacity-50 font-light mt-2 max-w-sm mx-auto leading-relaxed">
                    Mohon maaf, saat ini sedang tidak ada Batch pendaftaran yang aktif. Silakan kembali lagi nanti atau pantau media sosial PIH UIN Jakarta.
                </p>
            </div>
        )}
    </main>

    <nav class="dock-wrapper">
        <ul class="toolbar">
            <li class="toolbarItem">
                <a class="toolbarLink" href="/">
                    <span class="tooltip">Home</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </a>
            </li>
            <li class="toolbarItem">
                <a class="toolbarLink" href="/teams">
                    <span class="tooltip">Hall of Fame</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </a>
            </li>
            <li class="toolbarItem">
                <a class="toolbarLink" href="/join" style="background: var(--pih-dark); color: white;">
                    <span class="tooltip">Register</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="16" y1="11" x2="22" y2="11"/></svg>
                </a>
            </li>
        </ul>
    </nav>

    <script>
        import { gsap } from "gsap";
        import { supabase } from '../lib/supabase';

        // --- 1. DOCK ANIMATION ---
        const dock = document.querySelector(".toolbar") as HTMLElement;
        const icons = document.querySelectorAll(".toolbarItem");
        if (dock && icons.length > 0) {
            const firstIcon = icons[0] as HTMLElement;
            const min = 48; const max = 100; const bound = min * Math.PI;
            gsap.set(icons, { transformOrigin: "50% 120%", height: 40 });
            dock.addEventListener("mousemove", (event: MouseEvent) => {
                const rect = dock.getBoundingClientRect();
                const firstIcon = icons[0] as HTMLElement;
                const offset = rect.left + firstIcon.offsetLeft;
                const pointer = event.clientX - offset;
                icons.forEach((icon, i) => {
                    const distance = (i * min + min / 2) - pointer;
                    let x = 0, scale = 1;
                    if (Math.abs(distance) < bound) {
                        const rad = distance / min * 0.5;
                        scale = 1 + (max / min - 1) * Math.cos(rad);
                        x = 2 * (max - min) * Math.sin(rad);
                    } else { x = (distance < 0 ? 2 : -2) * (max - min); }
                    gsap.to(icon, { duration: 0.3, x: x, scale: scale, ease: "power3.out" });
                });
            });
            dock.addEventListener("mouseleave", () => gsap.to(icons, { duration: 0.3, scale: 1, x: 0 }));
        }

        // --- 2. SUPABASE SUBMISSION LOGIC ---
        const form = document.getElementById('apply-form') as HTMLFormElement | null;
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
        const batchIdInput = document.getElementById('batch_id_val') as HTMLInputElement | null;

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!submitBtn) return;

            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span>MENYIMPAN...</span>`;

            // Cek Sesi User
            const { data: { user } } = await supabase.auth.getUser();

            if (!user) {
                alert("Sesi berakhir. Silakan login kembali melalui halaman utama.");
                window.location.href = '/';
                return;
            }

            const activeBatchId = batchIdInput?.value || "unspecified";

            // Validasi Duplikasi
            const { data: existingEntry, error: checkError } = await supabase
                .from('applications')
                .select('id')
                .eq('user_email', user.email)
                .eq('batch_id', activeBatchId)
                .maybeSingle();

            if (checkError) {
                console.error("Check error:", checkError);
            }

            if (existingEntry) {
                alert("Anda sudah terdaftar di Batch ini. Silakan cek progres Anda di Dashboard.");
                window.location.href = '/dashboard';
                return;
            }

            // Konstruksi Payload Data (Sesuai Struktur Baru)
            const formData = {
                user_id: user.id,
                user_email: user.email,
                full_name: (document.getElementById('full_name') as HTMLInputElement).value,
                phone: (document.getElementById('phone') as HTMLInputElement).value,
                faculty: (document.getElementById('faculty') as HTMLInputElement).value,
                study_program: (document.getElementById('study_program') as HTMLInputElement).value,
                nim: (document.getElementById('nim') as HTMLInputElement).value,
                semester: parseInt((document.getElementById('semester') as HTMLInputElement).value),
                other_activities: (document.getElementById('other_activities') as HTMLTextAreaElement).value,
                role_applied: (document.getElementById('role_1') as HTMLSelectElement).value,
                role_2: (document.getElementById('role_2') as HTMLSelectElement).value,
                reason_1: (document.getElementById('reason_1') as HTMLTextAreaElement).value,
                reason_2: (document.getElementById('reason_2') as HTMLTextAreaElement).value,
                portfolio_url: (document.getElementById('portfolio_url') as HTMLInputElement).value,
                batch_id: activeBatchId, 
                status: 'administrasi',
                acknowledged: false
            };

            const { error: insertError } = await supabase
                .from('applications')
                .insert([formData]);

            if (insertError) {
                alert("Terjadi kesalahan database: " + insertError.message);
                submitBtn.disabled = false;
                submitBtn.innerText = "Kirim Lamaran Sekarang";
            } else {
                window.location.href = '/dashboard';
            }
        });
    </script>
</body>
</html>