---
import '../styles/global.css';
// Halaman Dashboard untuk pelamar memantau status secara real-time
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard | Life at PIH</title>
    <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Funnel Display', sans-serif; }
        .glass-card { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
        .progress-dot { transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
    </style>
</head>
<body class="bg-slate-50 min-h-screen">
    <nav class="bg-[#0f2854] text-white p-4 sticky top-0 z-50">
        <div class="max-w-5xl mx-auto flex justify-between items-center text-sm font-bold">
            <div class="flex items-center gap-2">
                <div class="w-6 h-6 bg-white rounded flex items-center justify-center text-[#0f2854]">P</div>
                <span class="tracking-tighter">LIFE AT PIH</span>
            </div>
            <button id="logout-btn" class="text-red-400 hover:text-red-300 transition-colors uppercase tracking-widest text-[10px]">Logout</button>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto py-12 px-6">
        <!-- 1. LOADING STATE -->
        <div id="loading-state" class="text-center py-24">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-blue-900 mx-auto"></div>
            <p class="mt-4 text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Sinkronisasi Data...</p>
        </div>

        <!-- 2. MAIN DASHBOARD CONTENT -->
        <div id="dashboard-content" class="hidden">
            <header class="mb-10">
                <h1 class="text-4xl font-extrabold text-slate-900 leading-tight italic">Halo, <span id="user-name" class="text-[#1b509b]">-</span>!</h1>
                <p class="text-slate-400 font-medium mt-1">Pantau perkembangan aplikasi magang Anda di sini.</p>
            </header>

            <!-- TRACKING CARD -->
            <div class="glass-card p-10 rounded-[2.5rem] shadow-2xl shadow-blue-900/5 mb-8 overflow-hidden relative">
                <div class="flex justify-between items-center mb-12 font-bold">
                    <span class="text-slate-800 uppercase tracking-widest text-xs">Progress Tahapan</span>
                    <span id="badge-status" class="px-4 py-1.5 rounded-full text-[9px] bg-slate-100 uppercase tracking-[0.2em] border border-slate-200 font-black">-</span>
                </div>
                
                <div class="relative px-6 pb-6">
                    <!-- Background Line -->
                    <div class="absolute top-5 left-10 right-10 h-1.5 bg-slate-200/50 rounded-full"></div>
                    <!-- Active Progress Line -->
                    <div id="progress-bar" class="absolute top-5 left-10 h-1.5 bg-[#1b509b] transition-all duration-1000 ease-in-out rounded-full shadow-[0_0_15px_rgba(27,80,155,0.4)]" style="width: 0%"></div>

                    <div class="flex justify-between relative">
                        {['administrasi', 'interview', 'final'].map((step, i) => (
                            <div class="step-item flex flex-col items-center w-24 group" data-step={step}>
                                <div class="circle progress-dot w-12 h-12 rounded-2xl bg-white border-4 border-slate-100 flex items-center justify-center font-black text-slate-300 z-10 shadow-sm group-hover:scale-110 transition-transform">
                                    {i + 1}
                                </div>
                                <span class="mt-4 text-[9px] uppercase font-black text-center leading-tight tracking-widest text-slate-400 group-data-[active=true]:text-[#1b509b]">{step}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- INFO BOXES -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Applied Role -->
                <div id="status-info-box" class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm flex gap-6 items-center">
                    <div class="w-16 h-16 bg-blue-50 rounded-3xl flex items-center justify-center text-3xl shadow-inner border border-blue-100/50 text-blue-600">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/></svg>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Posisi Dilamar</p>
                        <p id="applied-role" class="text-xl font-black text-slate-900 italic leading-tight">-</p>
                    </div>
                </div>

                <!-- Batch ID -->
                <div id="batch-info-box" class="bg-[#0f2854] p-8 rounded-[2.5rem] shadow-lg flex gap-6 items-center">
                    <div class="w-16 h-16 bg-white/5 rounded-3xl flex items-center justify-center text-3xl border border-white/10 text-white italic font-black">
                        #
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-blue-200/40 uppercase tracking-widest mb-1">ID Angkatan</p>
                        <p id="applied-batch" class="text-xl font-black text-white uppercase tracking-tighter leading-tight">-</p>
                    </div>
                </div>
            </div>

            <!-- EMPTY STATE -->
            <div id="no-application" class="hidden text-center py-24 bg-white rounded-[3rem] border-2 border-dashed border-slate-200">
                <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6 text-4xl">🚀</div>
                <h3 class="text-xl font-black text-slate-800 uppercase tracking-tighter mb-2">Siap untuk Berkontribusi?</h3>
                <p class="mb-10 font-medium text-slate-400 max-w-xs mx-auto text-sm leading-relaxed">Belum ada lamaran aktif yang terdaftar atas akun Anda di batch ini.</p>
                <a href="/join" class="bg-[#1b509b] text-white px-12 py-5 rounded-2xl font-black uppercase tracking-widest text-xs shadow-2xl shadow-blue-900/30 hover:scale-105 transition-transform inline-block">Mulai Pendaftaran</a>
            </div>
        </div>
    </main>

    <script>
        import { supabase } from '../lib/supabase';

        const loadingState = document.getElementById('loading-state') as HTMLElement;
        const dashboardContent = document.getElementById('dashboard-content') as HTMLElement;
        const userName = document.getElementById('user-name') as HTMLElement;
        const badgeStatus = document.getElementById('badge-status') as HTMLElement;
        const progressBar = document.getElementById('progress-bar') as HTMLElement;
        const appliedRole = document.getElementById('applied-role') as HTMLElement;
        const appliedBatch = document.getElementById('applied-batch') as HTMLElement;
        const noApp = document.getElementById('no-application') as HTMLElement;
        const statusBox = document.getElementById('status-info-box') as HTMLElement;
        const batchBox = document.getElementById('batch-info-box') as HTMLElement;
        const logoutBtn = document.getElementById('logout-btn') as HTMLButtonElement;

        async function init() {
            try {
                // 1. Verifikasi Sesi
                const { data: { user } } = await supabase.auth.getUser();
                if (!user) { 
                    window.location.href = '/'; 
                    return; 
                }

                userName.innerText = user.user_metadata.full_name || user.email?.split('@')[0] || "Intern";

                // 2. Tarik Data Aplikasi Terbaru
                const { data: application, error } = await supabase
                    .from('applications')
                    .select('*')
                    .eq('user_id', user.id)
                    .order('created_at', { ascending: false })
                    .maybeSingle();

                if (error) throw error;

                // Transisi Loading
                loadingState.classList.add('hidden');
                dashboardContent.classList.remove('hidden');

                if (!application) {
                    noApp.classList.remove('hidden');
                    statusBox.classList.add('hidden');
                    batchBox.classList.add('hidden');
                    return;
                }

                // 3. Render Data ke UI
                appliedRole.innerText = application.role_applied || "General Position";
                appliedBatch.innerText = application.batch_id || "Legacy Batch";
                updateUI(application.status);

            } catch (e: any) {
                console.error("Dashboard Error:", e.message);
                if (loadingState) loadingState.innerHTML = `<p class="text-red-500 font-bold">Gagal memuat dashboard: ${e.message}</p>`;
            }
        }

        function updateUI(status: string) {
            if (!badgeStatus || !progressBar) return;
            
            badgeStatus.innerText = status;
            const steps = document.querySelectorAll('.step-item');
            
            let p = 0;
            // administrasi = 0%, interview = 50%, accepted/rejected = 100%
            if (status === 'interview') p = 50;
            if (status === 'accepted' || status === 'rejected') p = 100;
            
            progressBar.style.width = `${p}%`;

            steps.forEach((item) => {
                const s = (item as HTMLElement).dataset.step;
                const circle = item.querySelector('.circle') as HTMLElement;
                if (!circle) return;

                // Reset Status
                circle.classList.remove('bg-[#1b509b]', 'text-white', 'border-[#1b509b]', 'bg-emerald-500', 'bg-rose-500');
                (item as HTMLElement).dataset.active = "false";
                
                if (status === 'administrasi') {
                    if (s === 'administrasi') {
                        circle.classList.add('bg-[#1b509b]', 'text-white', 'border-[#1b509b]');
                        (item as HTMLElement).dataset.active = "true";
                    }
                } else if (status === 'interview') {
                    if (s === 'administrasi' || s === 'interview') {
                        circle.classList.add('bg-[#1b509b]', 'text-white', 'border-[#1b509b]');
                        (item as HTMLElement).dataset.active = "true";
                    }
                } else if (status === 'accepted') {
                    circle.classList.add('bg-emerald-500', 'text-white', 'border-emerald-500');
                    badgeStatus.className = "px-4 py-1.5 rounded-full text-[9px] bg-emerald-50 text-emerald-600 border border-emerald-100 font-black uppercase tracking-[0.2em]";
                    (item as HTMLElement).dataset.active = "true";
                } else if (status === 'rejected') {
                    circle.classList.add('bg-rose-500', 'text-white', 'border-rose-500');
                    badgeStatus.className = "px-4 py-1.5 rounded-full text-[9px] bg-rose-50 text-rose-600 border border-rose-100 font-black uppercase tracking-[0.2em]";
                    (item as HTMLElement).dataset.active = "true";
                }
            });
        }

        logoutBtn?.addEventListener('click', async () => {
            await supabase.auth.signOut();
            window.location.href = '/';
        });

        // Jalankan Inisialisasi
        init();
    </script>
</body>
</html>