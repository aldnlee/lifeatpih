---
import '../styles/global.css';
// Halaman internal Terproteksi untuk Admin PIH dengan Fitur Manajemen Massal & Kontrol Notifikasi
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Portal | Life at PIH</title>
    <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Funnel Display', sans-serif; }
        .admin-glass { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
        input[type="checkbox"] { width: 1.2rem; height: 1.2rem; cursor: pointer; }
        .status-pill { transition: all 0.3s ease; }
    </style>
</head>
<body class="bg-slate-100 min-h-screen">
    
    <!-- 1. LOADING STATE -->
    <div id="admin-loader" class="fixed inset-0 bg-white z-[9999] flex flex-col items-center justify-center">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-[#0f2854] mb-4"></div>
        <p class="text-[10px] font-bold tracking-[0.3em] uppercase text-slate-400">Otentikasi Sistem Admin...</p>
    </div>

    <!-- 2. LOGIN SCREEN (Untuk Admin) -->
    <div id="admin-login-screen" class="hidden fixed inset-0 bg-[#0f2854] z-[9998] flex items-center justify-center p-6">
        <div class="max-w-md w-full text-center">
            <div class="w-20 h-20 bg-white rounded-3xl flex items-center justify-center mx-auto mb-8 text-3xl shadow-2xl shadow-blue-500/20">🛡️</div>
            <h1 class="text-3xl font-black text-white uppercase italic mb-2 tracking-tighter">Admin Portal</h1>
            <p class="text-blue-200/60 text-sm mb-10 font-light italic">Pusat Informasi dan Humas UIN Jakarta.</p>
            
            <button id="admin-login-btn" class="w-full bg-white text-[#0f2854] font-black py-5 rounded-2xl flex items-center justify-center gap-4 hover:scale-[1.02] transition-transform shadow-xl uppercase tracking-widest text-xs">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12s5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24s8.955,20,20,20s20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/><path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/><path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/><path fill="#1976D2" d="M43.611,20.083L43.595,20L42,20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/></svg>
                Masuk Sebagai Admin
            </button>
            <a href="/" class="block mt-10 text-[10px] font-bold text-white/20 uppercase tracking-[0.4em] hover:text-white transition-colors">Kembali ke Beranda</a>
        </div>
    </div>

    <!-- 3. MAIN PORTAL CONTENT -->
    <div id="admin-content" class="hidden">
        <nav class="bg-[#0f2854] text-white p-6 shadow-lg sticky top-0 z-50">
            <div class="max-w-7xl mx-auto flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center text-[#0f2854] font-black">A</div>
                    <h1 class="font-extrabold text-xl tracking-tighter uppercase">Admin <span class="font-light opacity-50">Panel</span></h1>
                </div>
                <div class="flex items-center gap-4">
                    <span id="admin-email-tag" class="text-[10px] bg-white/10 px-4 py-1.5 rounded-full border border-white/20 font-bold uppercase tracking-widest"></span>
                    <button id="logout-admin-btn" class="text-xs bg-red-500/20 text-red-400 hover:bg-red-500 hover:text-white px-4 py-1.5 rounded-lg font-bold border border-red-500/20 transition-all">LOGOUT</button>
                </div>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto py-12 px-6 pb-32">
            <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div>
                    <h2 class="text-4xl font-black text-slate-900 uppercase italic leading-none">Database Pelamar</h2>
                    <p class="text-slate-500 mt-2">Kelola status rekrutmen secara massal atau per individu.</p>
                </div>
                
                <div class="flex flex-wrap gap-3">
                    <!-- Filter Posisi -->
                    <div class="relative group">
                        <select id="role-filter" class="bg-white border border-slate-200 px-6 py-3.5 rounded-2xl text-xs font-bold text-slate-600 outline-none focus:ring-2 focus:ring-blue-500 appearance-none min-w-[220px] shadow-sm cursor-pointer transition-all hover:border-blue-300">
                            <option value="all">Semua Posisi</option>
                        </select>
                        <div class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none opacity-40">▼</div>
                    </div>
                    <button id="refresh-btn" class="bg-white border border-slate-200 text-slate-600 px-6 py-3.5 rounded-2xl text-xs font-bold hover:bg-slate-50 transition-colors shadow-sm">🔄 Sinkron</button>
                </div>
            </div>

            <!-- FLOATING ACTION PANEL (Muncul saat ada seleksi) -->
            <div id="bulk-action-panel" class="hidden mb-8 bg-[#1b509b] p-5 rounded-[2.5rem] flex flex-col md:flex-row items-center justify-between shadow-2xl shadow-blue-900/40 animate-in slide-in-from-top duration-300 gap-4">
                <div class="flex items-center gap-4 ml-4">
                    <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center text-white text-lg">✨</div>
                    <span class="text-white font-black text-xs uppercase tracking-widest leading-none">
                        <span id="selected-count" class="text-2xl block text-yellow-300">0</span> Orang Terpilih
                    </span>
                </div>
                <div class="flex flex-wrap justify-center gap-2">
                    <button id="bulk-interview-btn" class="bg-amber-400 text-slate-900 px-6 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-amber-300 shadow-lg">Wawancara Massal</button>
                    <button id="bulk-accept-btn" class="bg-emerald-500 text-white px-6 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-emerald-400 shadow-lg">Terima Massal</button>
                    <button id="auto-reject-btn" class="bg-rose-500 text-white px-6 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-rose-400 shadow-lg" title="Tolak semua pelamar sisa di kategori ini">Tolak Sisanya</button>
                    <button id="clear-selection-btn" class="bg-white/10 text-white border border-white/20 px-6 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-white/20">Batal</button>
                </div>
            </div>

            <!-- TABLE CONTAINER -->
            <div class="bg-white rounded-[3rem] shadow-2xl shadow-slate-200/50 border border-slate-200 overflow-hidden transition-all">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-slate-50 border-b border-slate-200">
                        <tr>
                            <th class="px-8 py-7 w-12 text-center">
                                <input type="checkbox" id="master-checkbox" class="rounded-lg">
                            </th>
                            <th class="px-8 py-7 text-[10px] font-black uppercase tracking-widest text-slate-400">Data Pelamar</th>
                            <th class="px-8 py-7 text-[10px] font-black uppercase tracking-widest text-slate-400">Pilihan Role</th>
                            <th class="px-8 py-7 text-[10px] font-black uppercase tracking-widest text-slate-400 text-center">Status</th>
                            <th class="px-8 py-7 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Aksi Cepat</th>
                        </tr>
                    </thead>
                    <tbody id="applicant-list" class="divide-y divide-slate-100">
                        <!-- Data Baris Dimuat Dinamis -->
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script>
        import { supabase } from '../lib/supabase';

        interface Applicant {
            id: string;
            full_name: string;
            user_email: string;
            portfolio_url: string;
            role_applied: string;
            status: string;
            created_at: string;
            batch_id: string;
        }

        const ADMIN_EMAIL = "aldnlee.ale@gmail.com";
        const loader = document.getElementById('admin-loader');
        const loginScreen = document.getElementById('admin-login-screen');
        const content = document.getElementById('admin-content');
        const listContainer = document.getElementById('applicant-list');
        const emailTag = document.getElementById('admin-email-tag');
        const roleFilter = document.getElementById('role-filter') as HTMLSelectElement;
        const bulkPanel = document.getElementById('bulk-action-panel');
        const selectedCountText = document.getElementById('selected-count');
        const masterCheckbox = document.getElementById('master-checkbox') as HTMLInputElement;

        let allApplicants: Applicant[] = [];
        let selectedIds: string[] = [];

        // --- 1. OTENTIKASI & PROTEKSI ---
        async function checkAdminAccess() {
            const { data: { user } } = await supabase.auth.getUser();
            
            if (!user) {
                loader?.classList.add('hidden');
                loginScreen?.classList.remove('hidden');
                return;
            }

            if (user.email !== ADMIN_EMAIL) {
                alert("Akses Terbatas: Hanya email " + ADMIN_EMAIL + " yang dapat masuk ke portal ini.");
                await supabase.auth.signOut();
                window.location.href = "/";
                return;
            }

            // Tampilkan Dashboard Admin
            if (emailTag) emailTag.innerText = user.email;
            loader?.classList.add('hidden');
            loginScreen?.classList.add('hidden');
            content?.classList.remove('hidden');
            
            loadApplicants();
        }

        // --- 2. MANAJEMEN DATA ---
        async function loadApplicants() {
            if (!listContainer) return;
            
            listContainer.innerHTML = `<tr><td colspan="5" class="p-24 text-center">
                <div class="animate-spin h-10 w-10 border-b-2 border-blue-900 mx-auto mb-4 rounded-full"></div>
                <p class="text-[10px] font-black uppercase text-slate-300 tracking-widest">Sinkronisasi Database...</p>
            </td></tr>`;

            const { data, error } = await supabase
                .from('applications')
                .select('*')
                .order('created_at', { ascending: false });

            if (error) {
                listContainer.innerHTML = `<tr><td colspan="5" class="p-10 text-center text-red-500 font-bold italic">Koneksi Gagal: ${error.message}</td></tr>`;
                return;
            }

            allApplicants = data as Applicant[];
            renderFilterOptions();
            renderList();
        }

        function renderFilterOptions() {
            if (!roleFilter) return;
            const currentRole = roleFilter.value;
            const roles = [...new Set(allApplicants.map(a => a.role_applied))];
            
            roleFilter.innerHTML = `<option value="all">Semua Posisi (${allApplicants.length})</option>` + 
                roles.map(r => `<option value="${r}">${r}</option>`).join('');
            
            roleFilter.value = currentRole;
        }

        function renderList() {
            const filter = roleFilter.value;
            const filtered = filter === 'all' ? allApplicants : allApplicants.filter(a => a.role_applied === filter);
            
            if (filtered.length === 0) {
                listContainer!.innerHTML = `<tr><td colspan="5" class="p-24 text-center text-slate-300 italic font-medium">Data di kategori ini masih kosong.</td></tr>`;
                return;
            }

            listContainer!.innerHTML = filtered.map(app => `
                <tr class="hover:bg-slate-50 transition-all duration-300 group">
                    <td class="px-8 py-7 text-center">
                        <input type="checkbox" class="applicant-checkbox rounded-lg" value="${app.id}" ${selectedIds.includes(app.id) ? 'checked' : ''}>
                    </td>
                    <td class="px-8 py-7">
                        <div class="font-black text-slate-900 text-lg leading-tight mb-1 group-hover:text-blue-700 transition-colors">${app.full_name}</div>
                        <div class="text-xs text-slate-400 font-bold mb-2">${app.user_email}</div>
                        <div class="flex gap-2">
                             <a href="${app.portfolio_url}" target="_blank" class="text-[9px] text-blue-600 font-black uppercase tracking-tighter hover:underline bg-blue-50 px-2 py-0.5 rounded">Portfolio &rarr;</a>
                             <span class="text-[8px] bg-slate-100 text-slate-400 px-2 py-0.5 rounded font-black uppercase">#${app.batch_id || '??'}</span>
                        </div>
                    </td>
                    <td class="px-8 py-7">
                        <span class="bg-blue-50 text-blue-700 px-4 py-2 rounded-xl text-[10px] font-black border border-blue-100 italic shadow-inner">${app.role_applied}</span>
                    </td>
                    <td class="px-8 py-7 text-center">
                        <span class="status-pill px-4 py-2 rounded-full text-[9px] font-black uppercase tracking-widest shadow-sm ${getStatusClass(app.status)}">
                            ${app.status}
                        </span>
                    </td>
                    <td class="px-8 py-7 text-right">
                        <div class="flex justify-end gap-2">
                            <button onclick="updateStatus('${app.id}', 'interview')" class="bg-amber-100 text-amber-700 p-3 rounded-xl hover:bg-amber-500 hover:text-white transition-all shadow-sm" title="Pindah ke Tahap Interview">💬</button>
                            <button onclick="updateStatus('${app.id}', 'accepted')" class="bg-emerald-100 text-emerald-700 p-3 rounded-xl hover:bg-emerald-500 hover:text-white transition-all shadow-sm" title="Terima Magang">✅</button>
                            <button onclick="updateStatus('${app.id}', 'rejected')" class="bg-rose-100 text-rose-700 p-3 rounded-xl hover:bg-rose-500 hover:text-white transition-all shadow-sm" title="Tolak">❌</button>
                        </div>
                    </td>
                </tr>
            `).join('');

            attachCheckboxListeners();
        }

        // --- 3. LOGIKA SELEKSI MASSAL ---
        function attachCheckboxListeners() {
            const checkboxes = document.querySelectorAll('.applicant-checkbox');
            checkboxes.forEach(cb => {
                cb.addEventListener('change', (e) => {
                    const id = (e.target as HTMLInputElement).value;
                    if ((e.target as HTMLInputElement).checked) {
                        if (!selectedIds.includes(id)) selectedIds.push(id);
                    } else {
                        selectedIds = selectedIds.filter(sid => sid !== id);
                    }
                    updateBulkUI();
                });
            });
        }

        function updateBulkUI() {
            if (selectedIds.length > 0) {
                bulkPanel?.classList.remove('hidden');
                bulkPanel?.classList.add('flex');
                if (selectedCountText) selectedCountText.innerText = selectedIds.length.toString();
            } else {
                bulkPanel?.classList.remove('flex');
                bulkPanel?.classList.add('hidden');
                masterCheckbox.checked = false;
            }
        }

        masterCheckbox.addEventListener('change', () => {
            const filter = roleFilter.value;
            const currentShown = filter === 'all' ? allApplicants : allApplicants.filter(a => a.role_applied === filter);
            
            if (masterCheckbox.checked) {
                currentShown.forEach(a => { if (!selectedIds.includes(a.id)) selectedIds.push(a.id); });
            } else {
                const shownIds = currentShown.map(a => a.id);
                selectedIds = selectedIds.filter(id => !shownIds.includes(id));
            }
            renderList();
            updateBulkUI();
        });

        // --- 4. AKSI UPDATE ---
        async function bulkUpdate(newStatus: string) {
            const confirmAction = confirm(`Ubah status ${selectedIds.length} orang menjadi ${newStatus.toUpperCase()}?\nNotifikasi akan otomatis muncul di dashboard mereka.`);
            if (!confirmAction) return;

            // Penting: acknowledged: false agar popup muncul di dashboard user
            const { error } = await supabase
                .from('applications')
                .update({ status: newStatus, acknowledged: false })
                .in('id', selectedIds);

            if (error) alert("Gagal update massal: " + error.message);
            else { selectedIds = []; loadApplicants(); }
        }

        async function autoRejectOthers() {
            const filter = roleFilter.value;
            if (filter === 'all') { alert("Pilih satu posisi spesifik dahulu sebelum menggunakan fitur Auto-Reject."); return; }

            // Cari pelamar di role ini yang TIDAK dipilih dan masih berstatus administrasi
            const toReject = allApplicants
                .filter(a => a.role_applied === filter && !selectedIds.includes(a.id) && a.status === 'administrasi')
                .map(a => a.id);

            if (toReject.length === 0) { alert("Tidak ditemukan pelamar sisa di kategori ini untuk ditolak."); return; }

            const confirmAction = confirm(`PERINGATAN: Anda akan menolak ${toReject.length} orang di posisi "${filter}" yang tidak Anda centang.\nLanjutkan?`);
            if (!confirmAction) return;

            const { error } = await supabase
                .from('applications')
                .update({ status: 'rejected', acknowledged: false })
                .in('id', toReject);

            if (error) alert(error.message);
            else { selectedIds = []; loadApplicants(); }
        }

        function getStatusClass(status: string) {
            if (status === 'interview') return 'bg-amber-50 text-amber-600 border border-amber-100';
            if (status === 'accepted') return 'bg-emerald-50 text-emerald-600 border border-emerald-100';
            if (status === 'rejected') return 'bg-rose-50 text-rose-600 border border-rose-100';
            return 'bg-slate-100 text-slate-400 border border-slate-200';
        }

        // Global function for individual click
        (window as any).updateStatus = async (id: string, newStatus: string) => {
            const { error } = await supabase
                .from('applications')
                .update({ status: newStatus, acknowledged: false })
                .eq('id', id);

            if (error) alert(error.message);
            else loadApplicants();
        };

        // --- 5. EVENT LISTENERS ---
        roleFilter?.addEventListener('change', () => { 
            masterCheckbox.checked = false; 
            renderList(); 
            updateBulkUI();
        });

        document.getElementById('refresh-btn')?.addEventListener('click', loadApplicants);
        document.getElementById('bulk-interview-btn')?.addEventListener('click', () => bulkUpdate('interview'));
        document.getElementById('bulk-accept-btn')?.addEventListener('click', () => bulkUpdate('accepted'));
        document.getElementById('auto-reject-btn')?.addEventListener('click', autoRejectOthers);
        document.getElementById('clear-selection-btn')?.addEventListener('click', () => { selectedIds = []; renderList(); updateBulkUI(); });
        
        document.getElementById('admin-login-btn')?.addEventListener('click', async () => {
            await supabase.auth.signInWithOAuth({ provider: 'google', options: { redirectTo: window.location.href } });
        });
        
        document.getElementById('logout-admin-btn')?.addEventListener('click', async () => {
            await supabase.auth.signOut();
            window.location.reload();
        });

        // Start
        checkAdminAccess();
    </script>
</body>
</html>