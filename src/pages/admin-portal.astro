---
import '../styles/global.css';
// Halaman internal untuk Tim PIH mengelola status pelamar
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Portal | Life at PIH</title>
    <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Funnel Display', sans-serif; }
    </style>
</head>
<body class="bg-slate-100 min-h-screen">
    <nav class="bg-[#0f2854] text-white p-6 shadow-lg">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <h1 class="font-extrabold text-xl tracking-tighter">PIH ADMIN <span class="font-light opacity-50">Portal</span></h1>
            <a href="/" class="text-xs font-bold opacity-70 hover:opacity-100 transition-opacity">Keluar ke Website</a>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-12 px-6">
        <div class="mb-10">
            <h2 class="text-3xl font-black text-slate-900 uppercase italic">Manajemen Pelamar</h2>
            <p class="text-slate-500">Daftar mahasiswa yang mengirimkan lamaran magang via portal.</p>
        </div>

        <div class="bg-white rounded-[2rem] shadow-xl border border-slate-200 overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-slate-50 border-b border-slate-200">
                    <tr>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400">Pelamar</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400">Posisi</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400">Status Saat Ini</th>
                        <th class="px-8 py-5 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Aksi Tahapan</th>
                    </tr>
                </thead>
                <tbody id="applicant-list">
                    <!-- Data akan dimuat via JavaScript -->
                    <tr>
                        <td colspan="4" class="px-8 py-20 text-center text-slate-400">Memuat data pelamar...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>

    <script>
        import { supabase } from '../lib/supabase';

        const listContainer = document.getElementById('applicant-list');

        async function loadApplicants() {
            if (!listContainer) return;

            const { data, error } = await supabase
                .from('applications')
                .select('*')
                .order('created_at', { ascending: false });

            if (error) {
                listContainer.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-red-500">${error.message}</td></tr>`;
                return;
            }

            if (data.length === 0) {
                listContainer.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-slate-400">Belum ada lamaran masuk.</td></tr>`;
                return;
            }

            listContainer.innerHTML = data.map(app => `
                <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors">
                    <td class="px-8 py-6">
                        <div class="font-bold text-slate-900 text-lg">${app.full_name}</div>
                        <div class="text-xs text-slate-400">${app.user_email}</div>
                        <a href="${app.portfolio_url}" target="_blank" class="text-[10px] text-blue-600 font-bold hover:underline">LIHAT PORTOFOLIO →</a>
                    </td>
                    <td class="px-8 py-6">
                        <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-[11px] font-bold">${app.role_applied}</span>
                    </td>
                    <td class="px-8 py-6">
                        <span class="status-badge px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter ${getStatusClass(app.status)}">
                            ${app.status}
                        </span>
                    </td>
                    <td class="px-8 py-6 text-right">
                        <div class="flex justify-end gap-2">
                            <button onclick="updateStatus('${app.id}', 'interview')" class="bg-yellow-500 text-white p-2 rounded-lg hover:bg-yellow-600 shadow-sm" title="Lanjut Wawancara">
                                💬
                            </button>
                            <button onclick="updateStatus('${app.id}', 'accepted')" class="bg-green-500 text-white p-2 rounded-lg hover:bg-green-600 shadow-sm" title="Terima Magang">
                                ✅
                            </button>
                            <button onclick="updateStatus('${app.id}', 'rejected')" class="bg-red-500 text-white p-2 rounded-lg hover:bg-red-600 shadow-sm" title="Tolak">
                                ❌
                            </button>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        function getStatusClass(status: string) {
            if (status === 'administrasi') return 'bg-slate-100 text-slate-500';
            if (status === 'interview') return 'bg-yellow-100 text-yellow-700';
            if (status === 'accepted') return 'bg-green-100 text-green-700';
            if (status === 'rejected') return 'bg-red-100 text-red-700';
            return 'bg-slate-100 text-slate-500';
        }

        // Fungsi Global untuk Update Status
        (window as any).updateStatus = async (id: string, newStatus: string) => {
            const confirmAction = confirm(`Ubah status pelamar menjadi '${newStatus}'?`);
            if (!confirmAction) return;

            const { error } = await supabase
                .from('applications')
                .update({ status: newStatus })
                .eq('id', id);

            if (error) {
                alert("Gagal update: " + error.message);
            } else {
                loadApplicants(); // Refresh data
            }
        };

        // Jalankan saat load
        loadApplicants();
    </script>
</body>
</html>