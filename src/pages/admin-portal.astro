---
import '../styles/global.css';
// Halaman internal Terproteksi untuk Admin PIH
// Fitur: Filter, Search, Bulk Action, Auto-Reject, Export CSV, Stats + Email Status Tracker
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Portal | Life at PIH</title>
    <link href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Funnel Display', sans-serif; }
        .admin-glass { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
        input[type="checkbox"] { width: 1.1rem; height: 1.1rem; cursor: pointer; border-radius: 4px; }
        .stats-card { transition: transform 0.3s ease; }
        .stats-card:hover { transform: translateY(-5px); }
        .email-sent { color: #10b981; }    /* Hijau */
        .email-pending { color: #94a3b8; }   /* Abu-abu */
        .email-failed { color: #f43f5e; }    /* Merah */
    </style>
</head>
<body class="bg-slate-100 min-h-screen">
    
    <!-- 1. LOADING STATE -->
    <div id="admin-loader" class="fixed inset-0 bg-white z-[9999] flex flex-col items-center justify-center">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-[#0f2854] mb-4"></div>
        <p class="text-[10px] font-bold tracking-[0.3em] uppercase text-slate-400">Otentikasi Sistem Admin...</p>
    </div>

    <!-- 2. LOGIN SCREEN -->
    <div id="admin-login-screen" class="hidden fixed inset-0 bg-[#0f2854] z-[9998] flex items-center justify-center p-6">
        <div class="max-w-md w-full text-center text-white">
            <div class="w-20 h-20 bg-white rounded-3xl flex items-center justify-center mx-auto mb-8 text-3xl shadow-2xl shadow-blue-500/20">🛡️</div>
            <h1 class="text-3xl font-black uppercase italic mb-2 tracking-tighter">Admin Portal</h1>
            <p class="text-blue-200/60 text-sm mb-10 font-light italic">Pusat Informasi dan Humas UIN Jakarta.</p>
            <button id="admin-login-btn" class="w-full bg-white text-[#0f2854] font-black py-5 rounded-2xl flex items-center justify-center gap-4 hover:scale-[1.02] transition-transform shadow-xl uppercase tracking-widest text-xs">
                Login dengan Akun Admin
            </button>
        </div>
    </div>

    <!-- 3. MAIN PORTAL CONTENT -->
    <div id="admin-content" class="hidden">
        <nav class="bg-[#0f2854] text-white p-6 shadow-lg sticky top-0 z-50">
            <div class="max-w-7xl mx-auto flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center text-[#0f2854] font-black">A</div>
                    <h1 class="font-extrabold text-xl tracking-tighter uppercase italic">PIH <span class="font-light opacity-50">Admin</span></h1>
                </div>
                <div class="flex items-center gap-4">
                    <span id="admin-email-tag" class="text-[10px] bg-white/10 px-4 py-1.5 rounded-full border border-white/20 font-bold uppercase tracking-widest"></span>
                    <button id="logout-admin-btn" class="text-xs bg-red-500/20 text-red-400 hover:bg-red-500 hover:text-white px-4 py-1.5 rounded-lg font-bold border border-red-500/20 transition-all">LOGOUT</button>
                </div>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto py-10 px-6 pb-32">
            <!-- RINGKASAN STATS -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-10">
                <div class="stats-card bg-white p-6 rounded-[2rem] border border-slate-200 shadow-sm">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Total Pelamar</p>
                    <p id="stat-total" class="text-3xl font-black text-slate-900">0</p>
                </div>
                <div class="stats-card bg-amber-50 p-6 rounded-[2rem] border border-amber-100 shadow-sm">
                    <p class="text-[9px] font-black text-amber-600 uppercase tracking-widest mb-1">Interview</p>
                    <p id="stat-interview" class="text-3xl font-black text-amber-700">0</p>
                </div>
                <div class="stats-card bg-emerald-50 p-6 rounded-[2rem] border border-emerald-100 shadow-sm">
                    <p class="text-[9px] font-black text-emerald-600 uppercase tracking-widest mb-1">Diterima</p>
                    <p id="stat-accepted" class="text-3xl font-black text-emerald-700">0</p>
                </div>
                <div class="stats-card bg-rose-50 p-6 rounded-[2rem] border border-rose-100 shadow-sm">
                    <p class="text-[9px] font-black text-rose-600 uppercase tracking-widest mb-1">Ditolak</p>
                    <p id="stat-rejected" class="text-3xl font-black text-rose-700">0</p>
                </div>
            </div>

            <!-- SEARCH & FILTER BAR -->
            <div class="mb-8 flex flex-col lg:flex-row gap-4 items-center justify-between">
                <div class="flex flex-1 w-full gap-3">
                    <div class="relative flex-1">
                        <input type="text" id="search-input" placeholder="Cari Nama atau Email..." class="w-full bg-white border border-slate-200 px-6 py-4 rounded-2xl text-sm focus:ring-2 focus:ring-blue-500 outline-none shadow-sm">
                    </div>
                    <div class="relative">
                        <select id="role-filter" class="bg-white border border-slate-200 px-6 py-4 rounded-2xl text-xs font-bold text-slate-600 outline-none appearance-none min-w-[200px] shadow-sm cursor-pointer transition-all hover:border-blue-300">
                            <option value="all">Semua Posisi</option>
                        </select>
                        <div class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none opacity-40 text-[10px]">▼</div>
                    </div>
                </div>
                <div class="flex gap-2 w-full lg:w-auto">
                    <button id="export-csv-btn" class="flex-1 lg:flex-none bg-slate-800 text-white px-6 py-4 rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-slate-700 transition-colors">📥 Export Excel</button>
                    <button id="refresh-btn" class="bg-white border border-slate-200 p-4 rounded-2xl hover:bg-slate-50 transition-colors shadow-sm">🔄</button>
                </div>
            </div>

            <!-- FLOATING BULK PANEL -->
            <div id="bulk-action-panel" class="hidden mb-6 bg-[#1b509b] p-5 rounded-[2.5rem] flex flex-col md:flex-row items-center justify-between shadow-2xl animate-in fade-in slide-in-from-top duration-300 gap-4">
                <div class="flex items-center gap-4 ml-4 text-white">
                    <span class="text-xs font-black uppercase tracking-widest">
                        <span id="selected-count" class="text-2xl text-yellow-300">0</span> Terpilih
                    </span>
                </div>
                <div class="flex flex-wrap justify-center gap-2">
                    <button id="bulk-interview-btn" class="bg-amber-400 text-slate-900 px-6 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-amber-300">Interview Massal</button>
                    <button id="bulk-accept-btn" class="bg-emerald-500 text-white px-6 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-emerald-400">Terima Massal</button>
                    <button id="auto-reject-btn" class="bg-rose-500 text-white px-6 py-3 rounded-2xl text-[10px] font-black uppercase hover:bg-rose-400" title="Tolak sisa pelamar yang tidak dicentang di kategori ini">Tolak Sisanya</button>
                    <button id="clear-selection-btn" class="bg-white/10 text-white border border-white/20 px-6 py-3 rounded-2xl text-[10px] font-black uppercase hover:bg-white/20">Batal</button>
                </div>
            </div>

            <!-- TABLE -->
            <div class="bg-white rounded-[3rem] shadow-xl border border-slate-200 overflow-hidden overflow-x-auto">
                <table class="w-full text-left border-collapse min-w-[800px]">
                    <thead class="bg-slate-50 border-b border-slate-200 text-slate-400 font-black uppercase text-[10px] tracking-widest">
                        <tr>
                            <th class="px-8 py-7 w-12 text-center"><input type="checkbox" id="master-checkbox"></th>
                            <th class="px-6 py-7">Pelamar</th>
                            <th class="px-6 py-7 text-center">Status Email</th>
                            <th class="px-6 py-7 text-center">Status</th>
                            <th class="px-6 py-7 text-right">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="applicant-list" class="divide-y divide-slate-100">
                        <!-- Data Baris Dimuat Dinamis -->
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script>
        import { supabase } from '../lib/supabase';

        interface Applicant {
            id: string; full_name: string; user_email: string; portfolio_url: string;
            role_applied: string; status: string; created_at: string; batch_id: string;
            email_status: string; acknowledged: boolean;
        }

        const ADMIN_EMAIL = "aldnlee.ale@gmail.com";
        const loader = document.getElementById('admin-loader');
        const loginScreen = document.getElementById('admin-login-screen');
        const content = document.getElementById('admin-content');
        const listContainer = document.getElementById('applicant-list');
        const emailTag = document.getElementById('admin-email-tag');
        const roleFilter = document.getElementById('role-filter') as HTMLSelectElement;
        const searchInput = document.getElementById('search-input') as HTMLInputElement;
        const bulkPanel = document.getElementById('bulk-action-panel');
        const selectedCountText = document.getElementById('selected-count');
        const masterCheckbox = document.getElementById('master-checkbox') as HTMLInputElement;

        let allApplicants: Applicant[] = [];
        let selectedIds: string[] = [];

        // 1. OTENTIKASI & PROTEKSI
        async function checkAdminAccess() {
            const { data: { user } } = await supabase.auth.getUser();
            if (!user) { loader?.classList.add('hidden'); loginScreen?.classList.remove('hidden'); return; }
            if (user.email !== ADMIN_EMAIL) { alert("Akses Ditolak!"); await supabase.auth.signOut(); window.location.href = "/"; return; }
            
            if (emailTag) emailTag.innerText = user.email;
            loader?.classList.add('hidden');
            loginScreen?.classList.add('hidden');
            content?.classList.remove('hidden');
            loadApplicants();
        }

        // 2. MANAJEMEN DATA
        async function loadApplicants() {
            if (!listContainer) return;
            listContainer.innerHTML = `<tr><td colspan="5" class="p-20 text-center text-slate-300 animate-pulse uppercase text-xs font-black tracking-widest italic">Sinkronisasi Database...</td></tr>`;

            const { data, error } = await supabase.from('applications').select('*').order('created_at', { ascending: false });
            if (error) { alert("Database Error: " + error.message); return; }

            allApplicants = data as Applicant[];
            updateStats();
            renderFilterOptions();
            renderList();
        }

        function updateStats() {
            document.getElementById('stat-total')!.innerText = allApplicants.length.toString();
            document.getElementById('stat-interview')!.innerText = allApplicants.filter(a => a.status === 'interview').length.toString();
            document.getElementById('stat-accepted')!.innerText = allApplicants.filter(a => a.status === 'accepted').length.toString();
            document.getElementById('stat-rejected')!.innerText = allApplicants.filter(a => a.status === 'rejected').length.toString();
        }

        function renderFilterOptions() {
            const current = roleFilter.value;
            const roles = [...new Set(allApplicants.map(a => a.role_applied))];
            roleFilter.innerHTML = `<option value="all">Semua Posisi (${allApplicants.length})</option>` + 
                roles.map(r => `<option value="${r}">${r}</option>`).join('');
            roleFilter.value = current;
        }

        function renderList() {
            const filter = roleFilter.value;
            const search = searchInput.value.toLowerCase();
            
            const filtered = allApplicants.filter(a => {
                const matchRole = filter === 'all' || a.role_applied === filter;
                const matchSearch = a.full_name.toLowerCase().includes(search) || a.user_email.toLowerCase().includes(search);
                return matchRole && matchSearch;
            });

            if (filtered.length === 0) {
                listContainer!.innerHTML = `<tr><td colspan="5" class="p-20 text-center text-slate-400 italic font-medium">Data pelamar tidak ditemukan.</td></tr>`;
                return;
            }

            listContainer!.innerHTML = filtered.map(app => `
                <tr class="hover:bg-slate-50 transition-colors group">
                    <td class="px-8 py-7 text-center">
                        <input type="checkbox" class="applicant-checkbox" value="${app.id}" ${selectedIds.includes(app.id) ? 'checked' : ''}>
                    </td>
                    <td class="px-6 py-7">
                        <div class="font-black text-slate-900 text-lg leading-tight mb-1">${app.full_name}</div>
                        <div class="text-xs text-slate-400 font-bold mb-3">${app.user_email}</div>
                        <div class="flex items-center gap-2">
                             <a href="${app.portfolio_url}" target="_blank" class="text-[9px] text-blue-600 font-black uppercase bg-blue-50 px-2 py-0.5 rounded hover:bg-blue-600 hover:text-white transition-all">Portfolio &rarr;</a>
                             <span class="text-[9px] bg-slate-100 text-slate-400 px-2 py-0.5 rounded font-black uppercase tracking-widest">#${app.batch_id || '??'}</span>
                        </div>
                    </td>
                    <td class="px-6 py-7 text-center">
                        <div class="flex flex-col items-center gap-1 group/notif">
                            <span class="text-xl ${getEmailIconClass(app.email_status)}">${getEmailIcon(app.email_status)}</span>
                            <span class="text-[7px] font-black uppercase opacity-40 tracking-widest">${app.email_status || 'not_sent'}</span>
                        </div>
                    </td>
                    <td class="px-6 py-7 text-center">
                        <span class="px-4 py-2 rounded-full text-[9px] font-black uppercase tracking-widest shadow-sm border ${getStatusClass(app.status)}">${app.status}</span>
                    </td>
                    <td class="px-6 py-7 text-right">
                        <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button onclick="updateStatus('${app.id}', 'interview')" class="p-3 bg-amber-100 text-amber-600 rounded-xl hover:bg-amber-500 hover:text-white transition-all" title="Pindah ke Interview">💬</button>
                            <button onclick="updateStatus('${app.id}', 'accepted')" class="p-3 bg-emerald-100 text-emerald-600 rounded-xl hover:bg-emerald-500 hover:text-white transition-all" title="Terima">✅</button>
                            <button onclick="updateStatus('${app.id}', 'rejected')" class="p-3 bg-rose-100 text-rose-600 rounded-xl hover:bg-rose-500 hover:text-white transition-all" title="Tolak">❌</button>
                        </div>
                    </td>
                </tr>
            `).join('');

            attachCheckboxListeners();
        }

        // 3. LOGIKA MASAL
        function attachCheckboxListeners() {
            document.querySelectorAll('.applicant-checkbox').forEach(cb => {
                cb.addEventListener('change', (e) => {
                    const id = (e.target as HTMLInputElement).value;
                    if ((e.target as HTMLInputElement).checked) { if (!selectedIds.includes(id)) selectedIds.push(id); }
                    else { selectedIds = selectedIds.filter(sid => sid !== id); }
                    updateBulkUI();
                });
            });
        }

        function updateBulkUI() {
            if (selectedIds.length > 0) {
                bulkPanel?.classList.replace('hidden', 'flex');
                selectedCountText!.innerText = selectedIds.length.toString();
            } else {
                bulkPanel?.classList.replace('flex', 'hidden');
                masterCheckbox.checked = false;
            }
        }

        masterCheckbox.addEventListener('change', () => {
            const filter = roleFilter.value;
            const search = searchInput.value.toLowerCase();
            const visible = allApplicants.filter(a => 
                (filter === 'all' || a.role_applied === filter) && 
                (a.full_name.toLowerCase().includes(search) || a.user_email.toLowerCase().includes(search))
            );
            
            if (masterCheckbox.checked) {
                visible.forEach(a => { if (!selectedIds.includes(a.id)) selectedIds.push(a.id); });
            } else {
                const vIds = visible.map(v => v.id);
                selectedIds = selectedIds.filter(id => !vIds.includes(id));
            }
            renderList();
            updateBulkUI();
        });

        // 4. ACTIONS
        (window as any).updateStatus = async (id: string, newStatus: string) => {
            const { error } = await supabase.from('applications').update({ 
                status: newStatus, 
                acknowledged: false, 
                email_status: 'pending' 
            }).eq('id', id);
            if (!error) loadApplicants();
        };

        async function bulkUpdate(status: string) {
            if (!confirm(`Ubah ${selectedIds.length} orang ke status ${status.toUpperCase()}?`)) return;
            const { error } = await supabase.from('applications').update({ 
                status, 
                acknowledged: false, 
                email_status: 'pending' 
            }).in('id', selectedIds);
            
            if (!error) { selectedIds = []; loadApplicants(); updateBulkUI(); }
        }

        async function autoRejectOthers() {
            const filter = roleFilter.value;
            if (filter === 'all') { alert("Pilih satu role!"); return; }
            const toReject = allApplicants.filter(a => a.role_applied === filter && !selectedIds.includes(a.id) && a.status === 'administrasi').map(a => a.id);
            if (toReject.length === 0 || !confirm(`Tolak ${toReject.length} sisa pelamar?`)) return;
            await supabase.from('applications').update({ status: 'rejected', acknowledged: false, email_status: 'pending' }).in('id', toReject);
            loadApplicants();
        }

        function exportCSV() {
            const headers = ["Nama Lengkap", "Email", "Posisi", "Status", "Batch ID", "Portfolio"];
            const rows = allApplicants.map(a => [a.full_name, a.user_email, a.role_applied, a.status, a.batch_id, a.portfolio_url]);
            const content = [headers, ...rows].map(e => e.join(",")).join("\n");
            const blob = new Blob([content], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.setAttribute('href', url);
            a.setAttribute('download', `Database_Pelamar_PIH_${new Date().toISOString().split('T')[0]}.csv`);
            a.click();
        }

        // HELPER FUNCTIONS
        function getEmailIcon(s: string) { return s === 'sent' ? '📧' : s === 'failed' ? '⚠️' : s === 'pending' ? '⏳' : '⚪'; }
        function getEmailIconClass(s: string) { return s === 'sent' ? 'email-sent' : s === 'failed' ? 'email-failed' : 'email-pending'; }
        
        function getStatusClass(s: string) {
            if (s === 'interview') return 'bg-amber-50 text-amber-600 border-amber-100';
            if (s === 'accepted') return 'bg-emerald-50 text-emerald-600 border-emerald-100';
            if (s === 'rejected') return 'bg-rose-50 text-rose-600 border-rose-100';
            return 'bg-slate-50 text-slate-400 border-slate-200';
        }

        // EVENT LISTENERS
        roleFilter.addEventListener('change', () => { masterCheckbox.checked = false; renderList(); updateBulkUI(); });
        searchInput.addEventListener('input', () => renderList());
        document.getElementById('refresh-btn')?.addEventListener('click', loadApplicants);
        document.getElementById('export-csv-btn')?.addEventListener('click', exportCSV);
        document.getElementById('bulk-interview-btn')?.addEventListener('click', () => bulkUpdate('interview'));
        document.getElementById('bulk-accept-btn')?.addEventListener('click', () => bulkUpdate('accepted'));
        document.getElementById('auto-reject-btn')?.addEventListener('click', autoRejectOthers);
        document.getElementById('clear-selection-btn')?.addEventListener('click', () => { selectedIds = []; renderList(); updateBulkUI(); });
        document.getElementById('admin-login-btn')?.addEventListener('click', () => supabase.auth.signInWithOAuth({ provider: 'google', options: { redirectTo: window.location.href } }));
        document.getElementById('logout-admin-btn')?.addEventListener('click', async () => { await supabase.auth.signOut(); window.location.reload(); });

        checkAdminAccess();
    </script>
</body>
</html>